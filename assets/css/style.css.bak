/* ============================================
   NIKHIL JAGGI — AI/ML ENGINEER PORTFOLIO
   Clean Depth Animations · Photo Lighting · Fully Responsive
   ============================================ */

/* ==================== VARIABLES ==================== */
:root {
    --bg: #0a0a1a;
    --bg-2: #0d0d24;
    --bg-3: #12122e;
    --bg-card: rgba(15, 15, 40, 0.6);
    --bg-card-hover: rgba(20, 20, 55, 0.8);
    --text: #e8eaf6;
    --text-2: #9fa8c7;
    --text-3: #5c6485;
    --accent: #818cf8;
    --purple: #c084fc;
    --cyan: #22d3ee;
    --emerald: #34d399;
    --amber: #fbbf24;
    --rose: #fb7185;
    --gradient: linear-gradient(135deg, #818cf8 0%, #c084fc 50%, #22d3ee 100%);
    --gradient-text: linear-gradient(90deg, #818cf8, #c084fc, #22d3ee, #34d399, #818cf8);
    --border: rgba(129,140,248,0.08);
    --border-hover: rgba(129,140,248,0.2);
    --shadow-glow: 0 0 80px rgba(129,140,248,0.08);
    --shadow-card: 0 8px 32px rgba(0,0,0,0.5);
    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-display: 'Space Grotesk', 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --radius: 16px;
    --radius-sm: 10px;
    --radius-lg: 24px;
    --radius-full: 9999px;
    --ease: cubic-bezier(0.4, 0, 0.2, 1);
    --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
    --ease-out: cubic-bezier(0, 0, 0.2, 1);
    --space-xs: clamp(4px, 1vw, 8px);
    --space-sm: clamp(8px, 2vw, 16px);
    --space-md: clamp(16px, 3vw, 28px);
    --space-lg: clamp(28px, 5vw, 48px);
    --space-xl: clamp(48px, 8vw, 80px);
    --space-2xl: clamp(64px, 10vw, 140px);
}

/* ==================== RESET ==================== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; scroll-padding-top: 100px; }
body {
    font-family: var(--font); background: var(--bg); color: var(--text);
    line-height: 1.7; overflow-x: hidden;
    -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
}
::selection { background: rgba(129,140,248,0.3); color: #fff; }
a { color: var(--accent); text-decoration: none; transition: color 0.3s var(--ease); }
img { max-width: 100%; display: block; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); }

/* ==================== SCROLLBAR ==================== */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: rgba(129,140,248,0.2); border-radius: 5px; }
::-webkit-scrollbar-thumb:hover { background: rgba(129,140,248,0.4); }
html { scrollbar-width: thin; scrollbar-color: rgba(129,140,248,0.2) var(--bg); }

/* ==================== NOISE OVERLAY ==================== */
.noise, .noise-overlay {
    position: fixed; inset: 0; z-index: 9000; pointer-events: none; opacity: 0.018;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ==================== SCROLL PROGRESS ==================== */
.scroll-progress {
    display: none !important;
}

/* ==================== DEPTH TUNNEL CANVAS ==================== */
.depth-tunnel-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    opacity: 0.35;
    transition: opacity 0.6s var(--ease);
}
[data-theme="light"] .depth-tunnel-canvas {
    opacity: 0.15;
}
@media (prefers-reduced-motion: reduce) {
    .depth-tunnel-canvas { display: none; }
}
@media (max-width: 768px) {
    .depth-tunnel-canvas { opacity: 0.2; }
}

/* ==================== PRELOADER ==================== */
.preloader {
    position: fixed; inset: 0; z-index: 10000; background: var(--bg);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 40px;
    transition: opacity 0.8s var(--ease), visibility 0.8s var(--ease);
}
.preloader.loaded { opacity: 0; visibility: hidden; pointer-events: none; }
.preloader-inner { position: relative; width: 120px; height: 120px; display: flex; align-items: center; justify-content: center; }
.preloader-ring {
    position: absolute; inset: 0; border-radius: 50%;
    border: 2px solid transparent; border-top-color: var(--accent);
    animation: preloaderSpin 1.2s linear infinite;
}
.preloader-ring:nth-child(2) {
    inset: 10px; border-top-color: var(--purple); animation-duration: 1.8s; animation-direction: reverse;
}
.preloader-ring:nth-child(3) {
    inset: 20px; border-top-color: var(--cyan); animation-duration: 2.4s;
}
@keyframes preloaderSpin { to { transform: rotate(360deg); } }
.preloader-text {
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 800;
    background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    position: relative; z-index: 2;
}
.preloader-bar { width: 180px; height: 2px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; }
.preloader-bar-fill { width: 0; height: 100%; background: var(--gradient); animation: preloaderFill 2s var(--ease) forwards; }
@keyframes preloaderFill { to { width: 100%; } }
.preloader-percent {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600;
    color: var(--text-3); letter-spacing: 2px; margin-top: -20px;
    transition: color 0.3s var(--ease);
}

/* ==================== CUSTOM CURSOR ==================== */
.cursor {
    width: 8px; height: 8px; background: var(--accent); border-radius: 50%;
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;
    transform: translate(-50%, -50%); transition: transform 0.05s linear;
    box-shadow: 0 0 15px rgba(129,140,248,0.6);
    mix-blend-mode: screen;
}
.cursor-follower {
    width: 40px; height: 40px; border: 1.5px solid rgba(129,140,248,0.3); border-radius: 50%;
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9998;
    transform: translate(-50%, -50%);
    transition: width 0.4s var(--ease-bounce), height 0.4s var(--ease-bounce), border-color 0.3s var(--ease), background 0.3s var(--ease);
}
.cursor-follower.hover {
    width: 60px; height: 60px; border-color: rgba(129,140,248,0.6); background: rgba(129,140,248,0.05);
}

/* ==================== NAVBAR (HTML uses .navbar, .nav-container, .nav-menu, .nav-toggle) ==================== */
.navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 20px 0; transition: all 0.4s var(--ease);
}
.navbar.scrolled {
    padding: 12px 0;
    background: rgba(3,0,20,0.75);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    backdrop-filter: blur(24px) saturate(1.6);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 4px 30px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.03);
}
.nav-container {
    max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md);
    display: flex; align-items: center; justify-content: space-between;
}
.nav-menu {
    display: flex; align-items: center; gap: 4px;
}
.nav-toggle {
    display: none; flex-direction: column; gap: 5px; background: none;
    border: none; cursor: pointer; padding: 8px; z-index: 1001;
}
.nav-toggle span {
    display: block; width: 24px; height: 1.5px; background: var(--text);
    border-radius: 2px; transition: all 0.3s var(--ease); transform-origin: center;
}
.nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.nav-toggle.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* Logo */
.logo-mark {
    width: 40px; height: 40px; border-radius: var(--radius-sm);
    background: var(--gradient); display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 0.85rem; font-weight: 800; color: #fff;
    position: relative; overflow: hidden; flex-shrink: 0;
}
.logo-mark::after {
    content: ''; position: absolute; inset: -2px; background: var(--gradient); border-radius: var(--radius-sm);
    filter: blur(10px); opacity: 0.4; z-index: -1; animation: logoGlow 3s ease-in-out infinite;
}
.logo-mark-text { position: relative; z-index: 2; }
.logo-glow { position: absolute; inset: -4px; border-radius: inherit; background: var(--gradient); filter: blur(12px); opacity: 0.3; z-index: 0; }
.logo-text { font-family: var(--font-display); font-size: 0.9rem; font-weight: 600; color: var(--text-2); white-space: nowrap; }
.cta-dot {
    width: 7px; height: 7px; background: var(--emerald); border-radius: 50%;
    box-shadow: 0 0 8px rgba(52,211,153,0.4); animation: pulse 2s ease-in-out infinite;
}

/* ==================== THEME TOGGLE ==================== */
.theme-toggle {
    background: none; border: 1px solid var(--border); cursor: pointer;
    width: 38px; height: 38px; border-radius: 50%; display: flex;
    align-items: center; justify-content: center; padding: 0;
    position: relative; overflow: hidden;
    transition: all 0.3s var(--ease);
}
.theme-toggle:hover { border-color: var(--border-hover); background: rgba(129,140,248,0.06); }
.theme-toggle::after { display: none; }
.theme-icon-dark, .theme-icon-light {
    position: absolute; font-size: 0.85rem;
    transition: all 0.4s var(--ease-bounce);
}
[data-theme="dark"] .theme-icon-dark { opacity: 1; transform: rotate(0deg) scale(1); color: var(--amber); }
[data-theme="dark"] .theme-icon-light { opacity: 0; transform: rotate(90deg) scale(0.5); }
[data-theme="light"] .theme-icon-dark { opacity: 0; transform: rotate(-90deg) scale(0.5); }
[data-theme="light"] .theme-icon-light { opacity: 1; transform: rotate(0deg) scale(1); color: var(--amber); }

/* ==================== BUTTONS ==================== */
.btn {
    display: inline-flex; align-items: center; gap: 10px; padding: 14px 28px;
    border-radius: var(--radius-full); font-family: var(--font); font-size: 0.875rem;
    font-weight: 600; text-decoration: none; cursor: pointer; border: none;
    transition: all 0.35s var(--ease); position: relative; overflow: hidden;
    white-space: nowrap;
}
.btn i { transition: transform 0.3s var(--ease); }
.btn:hover i { transform: translateX(3px); }
.btn-primary {
    background: var(--gradient); color: #fff;
    box-shadow: 0 4px 20px rgba(129,140,248,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
}
.btn-primary::before {
    content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
    opacity: 0; transition: opacity 0.3s var(--ease);
}
.btn-primary:hover::before { opacity: 1; }
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 40px rgba(129,140,248,0.45); color: #fff; }
.btn-primary::after {
    content: ''; position: absolute; inset: -2px; background: var(--gradient); border-radius: inherit;
    z-index: -1; filter: blur(15px); opacity: 0; transition: opacity 0.4s var(--ease);
}
.btn-primary:hover::after { opacity: 0.5; }
.btn-glass {
    background: rgba(255,255,255,0.04); color: var(--text);
    border: 1px solid var(--border); -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
}
.btn-glass:hover { background: rgba(255,255,255,0.08); border-color: var(--border-hover); transform: translateY(-3px); color: var(--text); box-shadow: var(--shadow-card); }
.btn-sm { padding: 10px 20px; font-size: 0.82rem; }
.btn-full { width: 100%; justify-content: center; }
.btn-loading {
    pointer-events: none; opacity: 0.7;
}
.btn-loading span { opacity: 0; }
.btn-loading i { opacity: 0; }
.btn-loading::after {
    content: ''; position: absolute; width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
    border-radius: 50%; animation: btnSpin 0.6s linear infinite;
}
@keyframes btnSpin { to { transform: rotate(360deg); } }

/* ==================== MISSING KEYFRAMES ==================== */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

/* ==================== KEYBOARD HINT ==================== */
.kbd-hint {
    position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(20px);
    padding: 10px 22px; border-radius: var(--radius-full);
    background: rgba(3,0,20,0.88); -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border); z-index: 996;
    font-size: 0.72rem; font-weight: 500; color: var(--text-3);
    opacity: 0; visibility: hidden;
    transition: all 0.5s var(--ease);
    pointer-events: none; white-space: nowrap;
}
.kbd-hint.visible { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
.kbd-hint kbd {
    display: inline-block; padding: 2px 7px; border-radius: 4px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600;
    color: var(--text-2); margin: 0 1px;
}
[data-theme="light"] .kbd-hint { background: rgba(248,247,252,0.95); border-color: rgba(0,0,0,0.08); }
[data-theme="light"] .kbd-hint kbd { background: rgba(0,0,0,0.06); border-color: rgba(0,0,0,0.1); }

/* ==================== HERO ==================== */
.hero {
    min-height: 100vh; min-height: 100dvh; display: flex; align-items: center;
    position: relative; overflow: hidden; padding: 100px 0 60px;
}
.hero-blob {
    position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.12; pointer-events: none; z-index: 0;
}
.hero-blob-1 { width: clamp(350px, 50vw, 700px); height: clamp(350px, 50vw, 700px); background: var(--accent); top: -15%; left: -10%; animation: blobFloat1 20s ease-in-out infinite; }
.hero-blob-2 { width: clamp(300px, 45vw, 600px); height: clamp(300px, 45vw, 600px); background: var(--purple); bottom: -20%; right: -10%; animation: blobFloat2 25s ease-in-out infinite; }
.hero-blob-3 { width: clamp(250px, 35vw, 500px); height: clamp(250px, 35vw, 500px); background: var(--cyan); top: 40%; left: 50%; animation: blobFloat3 30s ease-in-out infinite; opacity: 0.08; }
@keyframes blobFloat1 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(80px,50px) scale(1.1); } 66% { transform: translate(-40px,80px) scale(0.95); } }
@keyframes blobFloat2 { 0%,100% { transform: translate(0,0) scale(1); } 33% { transform: translate(-60px,-40px) scale(1.08); } 66% { transform: translate(50px,-70px) scale(0.92); } }
@keyframes blobFloat3 { 0%,100% { transform: translate(-50%,-50%) scale(1); } 50% { transform: translate(-50%,-50%) scale(1.3); } }
.hero-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(129,140,248,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(129,140,248,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
    animation: gridPulse 6s ease-in-out infinite;
}
@keyframes gridPulse { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }
.hero-canvas { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }

.hero-content {
    max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); position: relative; z-index: 2;
    display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(30px, 5vw, 60px); align-items: center; width: 100%;
}
.hero-text { position: relative; z-index: 2; }

/* Hero Badge */
.hero-badge {
    display: inline-flex; align-items: center; gap: 10px; padding: 7px 18px 7px 12px;
    background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.15);
    border-radius: var(--radius-full); font-size: clamp(0.7rem, 1.5vw, 0.78rem); font-weight: 500; color: var(--emerald);
    margin-bottom: clamp(20px, 3vw, 32px); animation: badgeFloat 3s ease-in-out infinite;
    position: relative; overflow: hidden;
}
@keyframes badgeFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
.hero-badge-dot {
    width: 8px; height: 8px; background: var(--emerald); border-radius: 50%;
    box-shadow: 0 0 8px rgba(52,211,153,0.5); position: relative; flex-shrink: 0;
}
.hero-badge-dot::after {
    content: ''; position: absolute; inset: -4px; border-radius: 50%;
    border: 1.5px solid var(--emerald); animation: pingDot 2s ease-in-out infinite;
}
@keyframes pingDot { 0% { transform: scale(1); opacity: 0.6; } 100% { transform: scale(2.5); opacity: 0; } }

/* Hero Title */
.hero-title { margin-bottom: 20px; }
.hero-line { display: block; overflow: hidden; }
.hero-line:first-child {
    font-family: var(--font-display); font-size: clamp(0.9rem, 2vw, 1.3rem); font-weight: 500;
    color: var(--text-2); margin-bottom: 4px;
}
.hero-name {
    font-family: var(--font-display); font-size: clamp(2.2rem, 5.5vw, 5rem); font-weight: 800;
    color: var(--text); line-height: 1.05; letter-spacing: clamp(-2px, -0.04em, -3px);
    background: linear-gradient(135deg, #f1f0f5 0%, #818cf8 50%, #c084fc 100%);
    background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; animation: nameShimmer 4s ease-in-out infinite;
}
@keyframes nameShimmer { 0% { background-position: 0% center; } 50% { background-position: 100% center; } 100% { background-position: 0% center; } }
.hero-accent-dot { -webkit-text-fill-color: var(--cyan); }

/* Hero Terminal */
.hero-terminal {
    display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; margin-bottom: 18px;
    background: rgba(0,0,0,0.35); border: 1px solid rgba(129,140,248,0.15);
    border-radius: var(--radius-sm); font-family: var(--font-mono);
    font-size: clamp(0.68rem, 1.2vw, 0.78rem); white-space: nowrap; overflow: hidden; max-width: 100%;
}
.terminal-prompt { color: var(--emerald); font-weight: 600; }
.terminal-cmd { color: var(--cyan); font-weight: 500; }
.terminal-cursor { color: var(--accent); font-weight: 400; animation: termBlink 1s step-end infinite; }
@keyframes termBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* Hero Tagline */
.hero-tagline { margin-bottom: 16px; font-size: clamp(1.1rem, 2.2vw, 1.4rem); color: var(--text-2); font-weight: 500; line-height: 1.6; }
.tagline-static { color: var(--text-2); }
.tagline-rotate-wrap { display: inline-block; position: relative; overflow: hidden; vertical-align: bottom; height: 1.5em; min-width: 200px; }
.tagline-rotate { display: block; position: relative; }
.tagline-word {
    display: block; position: absolute; top: 0; left: 0; width: max-content;
    opacity: 0; transform: translateY(100%); transition: all 0.6s var(--ease-bounce);
    font-weight: 700; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.tagline-word.active { opacity: 1; transform: translateY(0); position: relative; }
.tagline-word.exit-up { opacity: 0; transform: translateY(-100%); }

/* Hero Description */
.hero-desc { font-size: clamp(0.88rem, 1.8vw, 1rem); color: var(--text-2); line-height: 1.85; max-width: 540px; margin-bottom: 32px; }
.hero-desc strong { color: var(--text); font-weight: 600; }

/* Hero CTA */
.hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: clamp(32px, 5vw, 56px); }

/* Hero Stats */
.hero-stats {
    display: flex; align-items: center; padding: clamp(16px, 2.5vw, 24px) 0;
    border-top: 1px solid var(--border); gap: 0; flex-wrap: wrap;
}
.hero-stat { flex: 1; text-align: center; min-width: 0; padding: 4px 2px; }
.hero-stat-num { font-family: var(--font-display); font-size: clamp(1.2rem, 2.5vw, 1.7rem); font-weight: 800; color: var(--text); letter-spacing: -1px; display: inline; }
.hero-stat-plus {
    font-family: var(--font-display); font-size: clamp(0.75rem, 1.5vw, 1rem); font-weight: 700;
    background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-stat-label { display: block; font-size: clamp(0.58rem, 1vw, 0.68rem); color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; font-weight: 500; }
.hero-stat-divider { width: 1px; height: 36px; background: var(--border); flex-shrink: 0; }

/* ==================== HERO PHOTO ==================== */
.hero-visual { display: flex; align-items: center; justify-content: center; }
.hero-photo-container {
    position: relative; width: clamp(260px, 30vw, 340px); height: clamp(260px, 30vw, 340px);
    display: flex; align-items: center; justify-content: center;
}
/* Photo Light Layer — ambient lighting behind photo */
.hero-photo-light-layer {
    position: absolute; inset: -40px; border-radius: 50%; z-index: 0;
    background: radial-gradient(circle, rgba(129,140,248,0.2) 0%, rgba(192,132,252,0.1) 40%, transparent 70%);
    animation: photoLightPulse 5s ease-in-out infinite;
    filter: blur(20px);
}
@keyframes photoLightPulse {
    0%,100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.15); opacity: 1; }
}
.hero-photo {
    width: clamp(200px, 22vw, 260px); height: clamp(200px, 22vw, 260px);
    object-fit: cover; object-position: center top; border-radius: 50%;
    position: relative; z-index: 2;
    border: 3px solid rgba(129,140,248,0.3);
    box-shadow: 0 0 60px rgba(129,140,248,0.15), 0 0 120px rgba(192,132,252,0.08);
    transition: all 0.6s var(--ease);
    /* Enhanced brightness and contrast for better lighting */
    filter: brightness(1.05) contrast(1.05) saturate(1.1);
}
.hero-photo:hover {
    transform: scale(1.04);
    box-shadow: 0 0 80px rgba(129,140,248,0.25), 0 0 160px rgba(192,132,252,0.15);
    filter: brightness(1.12) contrast(1.08) saturate(1.15);
}
.hero-photo-overlay {
    position: absolute; width: clamp(200px, 22vw, 260px); height: clamp(200px, 22vw, 260px); border-radius: 50%;
    left: 50%; top: 50%; transform: translate(-50%, -50%);
    background: linear-gradient(180deg, transparent 50%, rgba(3,0,20,0.4) 100%);
    z-index: 3; pointer-events: none;
}
.hero-photo-ring {
    position: absolute; inset: -20px; border-radius: 50%;
    border: 1px solid rgba(129,140,248,0.1); animation: ringRotate 20s linear infinite;
}
.hero-photo-ring::before {
    content: ''; position: absolute; top: -5px; left: 50%; width: 10px; height: 10px;
    background: var(--accent); border-radius: 50%; box-shadow: 0 0 15px rgba(129,140,248,0.6);
}
.hero-photo-ring-2 { inset: -45px; border-color: rgba(192,132,252,0.07); animation: ringRotate 30s linear infinite reverse; }
.hero-photo-ring-2::before { background: var(--purple); box-shadow: 0 0 12px rgba(192,132,252,0.5); width: 8px; height: 8px; }
@keyframes ringRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.hero-photo-glow {
    position: absolute; inset: -30px; border-radius: 50%;
    background: radial-gradient(circle, rgba(129,140,248,0.12) 0%, transparent 70%);
    animation: glowPulse 4s ease-in-out infinite; z-index: 0;
}
@keyframes glowPulse { 0%,100% { transform: scale(1); opacity: 0.5; } 50% { transform: scale(1.2); opacity: 1; } }

/* Photo Floating Badges */
.photo-badge {
    position: absolute; width: clamp(34px, 4vw, 42px); height: clamp(34px, 4vw, 42px); border-radius: 50%;
    background: rgba(255,255,255,0.05); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px);
    border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;
    font-size: clamp(0.8rem, 1.2vw, 1rem); z-index: 4; animation: chipFloat 5s ease-in-out infinite;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3); transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
}
.photo-badge:hover { transform: scale(1.2) translateY(-5px) !important; box-shadow: 0 8px 25px rgba(0,0,0,0.4); }
.photo-badge i { color: var(--accent); }
.photo-badge-1 { top: 5%; left: -5%; animation-delay: 0s; }
.photo-badge-1 i { color: #3776ab; }
.photo-badge-2 { top: -8%; right: 15%; animation-delay: 0.5s; }
.photo-badge-2 i { color: var(--purple); }
.photo-badge-3 { top: 40%; right: -10%; animation-delay: 1s; }
.photo-badge-3 i { color: #61dafb; }
.photo-badge-4 { bottom: 5%; right: 0%; animation-delay: 1.5s; }
.photo-badge-4 i { color: #f89820; }
.photo-badge-5 { bottom: 15%; left: -8%; animation-delay: 2s; }
.photo-badge-5 i { color: var(--cyan); }
.photo-badge-6 { top: 30%; left: -12%; animation-delay: 2.5s; }
.photo-badge-6 i { color: var(--amber); }
@keyframes chipFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

/* Hero Scroll */
.hero-scroll {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    animation: scrollFloat 2s ease-in-out infinite;
}
.hero-scroll span { font-size: 0.6rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 3px; font-weight: 500; }
.hero-scroll-mouse { width: 22px; height: 34px; border: 2px solid rgba(255,255,255,0.12); border-radius: 12px; display: flex; justify-content: center; }
.hero-scroll-wheel { width: 3px; height: 8px; background: var(--accent); border-radius: 2px; margin-top: 6px; animation: scrollWheel 2s ease-in-out infinite; }
@keyframes scrollWheel { 0% { transform: translateY(0); opacity: 1; } 100% { transform: translateY(12px); opacity: 0; } }
@keyframes scrollFloat { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(6px); } }

/* ==================== HERO TERMINAL ==================== */
.hero-terminal {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px; margin-bottom: 18px;
    background: rgba(0,0,0,0.35); border: 1px solid rgba(129,140,248,0.15);
    border-radius: var(--radius-sm); font-family: var(--font-mono);
    font-size: clamp(0.68rem, 1.2vw, 0.78rem); white-space: nowrap;
    overflow: hidden; max-width: 100%;
}
.terminal-prompt { color: var(--emerald); font-weight: 600; }
.terminal-cmd { color: var(--cyan); font-weight: 500; }
.terminal-cursor {
    color: var(--accent); font-weight: 400;
    animation: termBlink 1s step-end infinite;
}
@keyframes termBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* ==================== HERO TAGLINE ==================== */
.hero-tagline {
    margin-bottom: 16px;
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    color: var(--text-2); font-weight: 500;
    line-height: 1.6;
}
.tagline-static { color: var(--text-2); }
.tagline-rotate-wrap {
    display: inline-block;
    position: relative;
    overflow: hidden;
    vertical-align: bottom;
    height: 1.5em;
    min-width: 200px;
}
.tagline-rotate {
    display: block;
    position: relative;
}
.tagline-word {
    display: block;
    position: absolute;
    top: 0; left: 0;
    width: max-content;
    opacity: 0;
    transform: translateY(100%);
    transition: all 0.6s var(--ease-bounce);
    font-weight: 700;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}
.tagline-word.active {
    opacity: 1;
    transform: translateY(0);
    position: relative;
}
.tagline-word.exit-up {
    opacity: 0;
    transform: translateY(-100%);
}

/* ==================== HERO HUD OVERLAYS ==================== */
.hero-hud {
    position: absolute; z-index: 5; pointer-events: none;
    display: flex; flex-direction: column; gap: 2px;
    padding: 6px 10px; border-radius: 6px;
    background: rgba(3,0,20,0.6); -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(129,140,248,0.12);
    font-family: var(--font-mono);
    opacity: 0; animation: hudFadeIn 0.6s var(--ease) forwards;
}
.hero-hud-tl { top: 8%; left: -60px; animation-delay: 3.6s; }
.hero-hud-tr { top: 8%; right: -60px; animation-delay: 3.8s; }
.hero-hud-bl { bottom: 18%; left: -65px; animation-delay: 4.0s; }
.hero-hud-br { bottom: 18%; right: -55px; animation-delay: 4.2s; }
@keyframes hudFadeIn {
    from { opacity: 0; transform: translateY(6px) scale(0.92); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}
.hud-label {
    font-size: 0.5rem; font-weight: 700; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 1.5px;
}
.hud-value {
    font-size: 0.62rem; font-weight: 600; color: var(--accent);
    letter-spacing: 0.5px;
}
.hud-online { color: var(--emerald); }
.hud-xp {
    background: var(--gradient); -webkit-background-clip: text;
    -webkit-text-fill-color: transparent; background-clip: text;
}

/* ==================== HERO HOLOGRAM RINGS ==================== */
.hero-hologram-ring {
    position: absolute; border-radius: 50%; pointer-events: none; z-index: 1;
    border: 1px solid rgba(129,140,248,0.08);
}
.hero-hologram-ring-1 {
    inset: -25px; animation: holoRing 18s linear infinite;
    border-color: rgba(129,140,248,0.1);
    border-style: dashed;
}
.hero-hologram-ring-2 {
    inset: -50px; animation: holoRing 28s linear infinite reverse;
    border-color: rgba(192,132,252,0.06);
}
.hero-hologram-ring-3 {
    inset: -75px; animation: holoRing 38s linear infinite;
    border-color: rgba(34,211,238,0.04);
    border-style: dotted;
}
@keyframes holoRing { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

/* ==================== HERO MATRIX RAIN ==================== */
.hero-matrix {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    overflow: hidden; opacity: 0.04;
}
.matrix-col {
    position: absolute; top: -100%; font-family: var(--font-mono);
    font-size: 12px; color: var(--emerald); line-height: 1.4;
    writing-mode: vertical-rl; text-orientation: mixed;
    animation: matrixFall linear infinite;
    opacity: 0.7;
}
@keyframes matrixFall {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(calc(100vh + 100%)); }
}

/* ==================== HERO NEURAL BG ==================== */
.hero-neural-bg {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: 0; opacity: 0.5;
}

/* ==================== SCROLL MASCOT ==================== */
.scroll-mascot {
    position: fixed; bottom: 90px; left: 28px; z-index: 997;
    opacity: 0; transform: translateY(30px) scale(0.7);
    transition: all 0.5s var(--ease-bounce);
    pointer-events: none;
}
.scroll-mascot.visible {
    opacity: 1; transform: translateY(0) scale(1);
    pointer-events: auto;
}
.mascot-body {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--gradient); position: relative;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(129,140,248,0.3);
    animation: mascotBob 3s ease-in-out infinite;
    cursor: pointer;
}
@keyframes mascotBob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
}
.mascot-eye {
    width: 5px; height: 6px; background: #fff; border-radius: 50%;
    position: absolute; top: 14px;
}
.mascot-eye-l { left: 12px; }
.mascot-eye-r { right: 12px; }
.mascot-mouth {
    width: 10px; height: 5px; border-bottom: 2px solid #fff;
    border-radius: 0 0 5px 5px; position: absolute; bottom: 12px;
    left: 50%; transform: translateX(-50%);
}
.mascot-antenna {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    width: 2px; height: 10px; background: rgba(255,255,255,0.5);
}
.mascot-antenna-ball {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cyan); position: absolute; top: -4px; left: -2px;
    box-shadow: 0 0 8px rgba(34,211,238,0.6);
    animation: antennaPulse 2s ease-in-out infinite;
}
@keyframes antennaPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
}
.mascot-speech {
    position: absolute; bottom: calc(100% + 10px); left: 50%;
    transform: translateX(-50%) translateY(6px); white-space: nowrap;
    padding: 6px 14px; border-radius: var(--radius-full);
    background: rgba(3,0,20,0.88); -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(129,140,248,0.2);
    font-size: 0.68rem; font-weight: 500; color: var(--text-2);
    opacity: 0; transform: translateX(-50%) translateY(6px);
    transition: all 0.3s var(--ease);
    pointer-events: none;
}
.mascot-speech.visible {
    opacity: 1; transform: translateX(-50%) translateY(0);
}
.mascot-speech::after {
    content: ''; position: absolute; bottom: -5px; left: 50%; transform: translateX(-50%);
    border: 5px solid transparent; border-top-color: rgba(3,0,20,0.88);
}

/* ==================== NIKHIL BOT MASCOT ==================== */
.nikhil-bot {
    position: fixed;
    bottom: 90px;
    left: 24px;
    z-index: 997;
    opacity: 0;
    transform: translateY(40px) scale(0.6);
    transition: all 0.6s var(--ease-bounce);
    pointer-events: none;
    cursor: pointer;
}
.nikhil-bot.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
}
.bot-container {
    position: relative;
    width: 60px;
    height: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.bot-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    position: relative;
    overflow: visible;
    animation: botBob 3s ease-in-out infinite;
}
@keyframes botBob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-4px) rotate(-2deg); }
    75% { transform: translateY(-2px) rotate(2deg); }
}
.bot-face {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--accent);
    box-shadow: 0 0 20px rgba(129,140,248,0.3);
}
.bot-glasses {
    position: absolute;
    top: 16px;
    left: 6px;
    width: 36px;
    height: 12px;
    border: 2px solid rgba(129,140,248,0.8);
    border-radius: 6px;
    background: rgba(129,140,248,0.1);
    pointer-events: none;
}
.bot-glasses::before, .bot-glasses::after {
    content: '';
    position: absolute;
    top: 1px;
    width: 12px;
    height: 8px;
    border-radius: 4px;
    background: rgba(129,140,248,0.15);
    border: 1px solid rgba(129,140,248,0.4);
}
.bot-glasses::before { left: 2px; }
.bot-glasses::after { right: 2px; }
.bot-antenna {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 12px;
    background: var(--accent);
}
.bot-antenna-ball {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--cyan);
    position: absolute;
    top: -5px;
    left: -3px;
    box-shadow: 0 0 12px rgba(34,211,238,0.8);
    animation: antennaPulse 2s ease-in-out infinite;
}
.bot-body {
    width: 32px;
    height: 20px;
    background: var(--gradient);
    border-radius: 0 0 16px 16px;
    position: relative;
    margin-top: -4px;
}
.bot-arm {
    position: absolute;
    width: 6px;
    height: 18px;
    background: var(--accent);
    border-radius: 3px;
    top: 2px;
    transition: transform 0.4s var(--ease-bounce);
    transform-origin: top center;
}
.bot-arm-left { left: -8px; transform: rotate(0deg); }
.bot-arm-right { right: -8px; transform: rotate(0deg); }

/* Bot action states */
.nikhil-bot.waving .bot-arm-right {
    animation: botWave 0.6s ease-in-out 3;
}
@keyframes botWave {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-40deg); }
}
.nikhil-bot.studying .bot-arm-left {
    transform: rotate(30deg);
}
.nikhil-bot.studying .bot-arm-right {
    transform: rotate(-30deg);
}
.nikhil-bot.building .bot-arm-left {
    animation: botHammer 0.4s ease-in-out infinite;
}
@keyframes botHammer {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-45deg); }
}
.nikhil-bot.celebrating .bot-arm-left,
.nikhil-bot.celebrating .bot-arm-right {
    animation: botCelebrate 0.5s ease-in-out infinite alternate;
}
@keyframes botCelebrate {
    0% { transform: rotate(-30deg); }
    100% { transform: rotate(-60deg); }
}
.nikhil-bot.coding .bot-arm-left {
    animation: botType 0.3s ease-in-out infinite alternate;
}
.nikhil-bot.coding .bot-arm-right {
    animation: botType 0.3s ease-in-out infinite alternate-reverse;
}
@keyframes botType {
    0% { transform: rotate(10deg); }
    100% { transform: rotate(20deg); }
}

.bot-action-icon {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    color: #fff;
    box-shadow: 0 2px 10px rgba(129,140,248,0.4);
    opacity: 0;
    transform: scale(0);
    transition: all 0.4s var(--ease-bounce);
}
.nikhil-bot.has-action .bot-action-icon {
    opacity: 1;
    transform: scale(1);
}

.bot-speech {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    white-space: nowrap;
    padding: 6px 14px;
    border-radius: var(--radius-full);
    background: rgba(3,0,20,0.9);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(129,140,248,0.2);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-2);
    opacity: 0;
    transition: all 0.4s var(--ease);
    pointer-events: none;
}
.bot-speech.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
}
.bot-speech::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgba(3,0,20,0.9);
}

/* ==================== SKIP TO CONTENT ==================== */
.skip-to-content {
    position: fixed; top: -100%; left: 50%; transform: translateX(-50%);
    padding: 12px 24px; background: var(--accent); color: #fff; z-index: 10002;
    border-radius: var(--radius-full); font-weight: 600; font-size: 0.85rem;
    transition: top 0.3s var(--ease);
}
.skip-to-content:focus { top: 16px; }

/* ==================== TEXT GRADIENT UTILITY ==================== */
.text-gradient {
    background: var(--gradient); -webkit-background-clip: text;
    -webkit-text-fill-color: transparent; background-clip: text;
}

/* ==================== NODE PULSE (SVG) ==================== */
.node-pulse {
    animation: nodePulseAnim 3s ease-in-out infinite;
}
@keyframes nodePulseAnim {
    0%, 100% { opacity: 0.3; r: 3; }
    50% { opacity: 0.8; r: 5; }
}

/* ==================== MARQUEE ==================== */
.marquee-strip {
    padding: 18px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    overflow: hidden; position: relative; background: rgba(255,255,255,0.01);
}
.marquee-track { display: flex; width: max-content; }
.marquee-content {
    display: flex; align-items: center; gap: 24px; white-space: nowrap;
    animation: marqueeScroll 30s linear infinite;
    font-size: 0.82rem; font-weight: 500; color: var(--text-3);
}
.marquee-content span { display: inline-flex; align-items: center; gap: 8px; }
.marquee-content i { color: var(--accent); font-size: 0.9rem; }
.marquee-diamond { color: var(--purple); font-size: 0.5rem; opacity: 0.4; }
@keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* ==================== SECTIONS ==================== */
.section {
    padding: var(--space-2xl) 0; position: relative; overflow: hidden;
}
.section-alt { background: var(--bg-2); }
.section-glow {
    position: absolute; width: clamp(300px, 40vw, 600px); height: clamp(300px, 40vw, 600px);
    border-radius: 50%; filter: blur(150px); opacity: 0.06; pointer-events: none;
}
.section-glow-purple { background: var(--purple); top: -10%; right: -5%; }
.section-glow-cyan { background: var(--cyan); top: 10%; left: -10%; }
.section-glow-rose { background: var(--rose); top: -5%; right: -8%; }
.section-glow-amber { background: var(--amber); top: 20%; left: -10%; }

.section-header { text-align: center; margin-bottom: var(--space-xl); }
.section-num {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
    color: var(--accent); text-transform: uppercase; letter-spacing: 3px;
    display: block; margin-bottom: 12px;
}
.section-title {
    font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800; color: var(--text); line-height: 1.15; letter-spacing: -1px;
    margin-bottom: 16px;
}
.section-line {
    width: 60px; height: 3px; background: var(--gradient); margin: 0 auto 16px;
    border-radius: 3px;
}
.section-desc {
    font-size: clamp(0.88rem, 1.5vw, 1rem); color: var(--text-2); max-width: 520px; margin: 0 auto;
}

/* ==================== MOBILE FAB ==================== */
.mobile-fab {
    display: none; position: fixed; bottom: 20px; right: 20px; z-index: 998;
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--gradient); color: #fff; border: none;
    align-items: center; justify-content: center; font-size: 1.1rem;
    box-shadow: 0 4px 20px rgba(129,140,248,0.4); cursor: pointer;
    transition: transform 0.3s var(--ease);
}
.mobile-fab:hover { transform: scale(1.1); }
.mobile-fab.visible { display: flex; }

/* ==================== ABOUT ==================== */
.about-grid {
    display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(40px, 6vw, 80px); align-items: start;
}
.about-left { position: relative; }
.about-photo-wrap {
    position: relative; border-radius: var(--radius-lg); overflow: hidden;
    aspect-ratio: 3/4; max-width: 320px;
}
.about-photo {
    width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-lg);
    transition: transform 0.6s var(--ease);
}
.about-photo-wrap:hover .about-photo { transform: scale(1.04); }
.about-photo-border {
    position: absolute; inset: -1px; border-radius: var(--radius-lg);
    border: 1px solid var(--border); pointer-events: none;
}
.about-photo-dots {
    position: absolute; bottom: -12px; right: -12px; width: 80px; height: 80px;
    background-image: radial-gradient(rgba(129,140,248,0.2) 1.5px, transparent 1.5px);
    background-size: 10px 10px; pointer-events: none; z-index: -1;
}
.about-exp-badge {
    position: absolute; bottom: 20px; left: -20px;
    padding: 12px 20px; border-radius: var(--radius-sm);
    background: rgba(3,0,20,0.85); -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border); display: flex; flex-direction: column;
    align-items: center; gap: 2px; z-index: 2;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
}
.about-exp-num {
    font-family: var(--font-display); font-size: 1.2rem; font-weight: 800;
    background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.about-exp-label { font-size: 0.65rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }

.about-right {}
.about-headline {
    font-family: var(--font-display); font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 700; line-height: 1.35; margin-bottom: 20px; color: var(--text);
}
.about-lead {
    font-size: clamp(0.92rem, 1.5vw, 1.05rem); color: var(--text-2); line-height: 1.8;
    margin-bottom: 16px; padding-left: 16px; border-left: 3px solid var(--accent);
}
.about-lead em { color: var(--accent); font-style: italic; }
.about-right p { font-size: 0.92rem; color: var(--text-2); line-height: 1.8; margin-bottom: 14px; }
.about-right p strong { color: var(--text); font-weight: 600; }

/* About Learning */
.about-learning {
    margin: 28px 0; padding: 20px; border-radius: var(--radius); border: 1px solid var(--border);
    background: var(--bg-card);
}
.about-learning-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
    font-size: 0.82rem; font-weight: 600; color: var(--accent);
}
.about-learning-header i { font-size: 0.9rem; }
.about-learning-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.learning-tag {
    display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px;
    border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 500;
    background: rgba(129,140,248,0.06); border: 1px solid rgba(129,140,248,0.12);
    color: var(--text-2); transition: all 0.3s var(--ease);
}
.learning-tag:hover { background: rgba(129,140,248,0.12); border-color: rgba(129,140,248,0.25); color: var(--text); }
.learning-tag i { color: var(--accent); font-size: 0.7rem; }

/* About Info Grid */
.about-info-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 24px;
}
.about-info-item {
    display: flex; align-items: flex-start; gap: 12px; padding: 14px;
    border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: var(--bg-card); transition: all 0.3s var(--ease);
}
.about-info-item:hover { border-color: var(--border-hover); background: var(--bg-card-hover); }
.about-info-item i {
    font-size: 0.9rem; color: var(--accent); margin-top: 3px; flex-shrink: 0; width: 18px; text-align: center;
}
.about-info-item div { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.about-info-item span { font-size: 0.68rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }
.about-info-item strong { font-size: 0.82rem; color: var(--text); font-weight: 600; }

/* ==================== VALUE CARDS ==================== */
.value-cards {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
}
.value-card {
    position: relative; padding: clamp(24px, 3vw, 36px);
    border-radius: var(--radius-lg); border: 1px solid var(--border);
    background: var(--bg-card); overflow: hidden;
    transition: all 0.4s var(--ease);
}
.value-card:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateY(-6px); box-shadow: var(--shadow-card); }
.value-card-icon {
    width: 48px; height: 48px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 1.15rem; color: var(--accent); margin-bottom: 20px;
    transition: transform 0.3s var(--ease-bounce), background 0.3s var(--ease);
}
.value-card:hover .value-card-icon { transform: scale(1.1); background: rgba(129,140,248,0.15); }
.value-icon-cyan { background: rgba(34,211,238,0.08); color: var(--cyan); }
.value-card:hover .value-icon-cyan { background: rgba(34,211,238,0.15); }
.value-icon-emerald { background: rgba(52,211,153,0.08); color: var(--emerald); }
.value-card:hover .value-icon-emerald { background: rgba(52,211,153,0.15); }
.value-icon-amber { background: rgba(251,191,36,0.08); color: var(--amber); }
.value-card:hover .value-icon-amber { background: rgba(251,191,36,0.15); }
.value-card-num {
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700;
    color: var(--text-3); letter-spacing: 2px; margin-bottom: 12px;
}
.value-card h3 {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 700;
    color: var(--text); margin-bottom: 10px;
}
.value-card p { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; }
.value-card-glow {
    position: absolute; bottom: -60px; right: -60px; width: 160px; height: 160px;
    border-radius: 50%; background: rgba(129,140,248,0.06); filter: blur(60px);
    pointer-events: none; transition: opacity 0.4s var(--ease); opacity: 0;
}
.value-card:hover .value-card-glow { opacity: 1; }
.value-glow-cyan { background: rgba(34,211,238,0.06); }
.value-glow-emerald { background: rgba(52,211,153,0.06); }
.value-glow-amber { background: rgba(251,191,36,0.06); }

/* ==================== SKILLS ==================== */
.skills-sphere-section {
    position: relative; display: flex; align-items: center; justify-content: center;
    margin-bottom: var(--space-xl); min-height: 300px;
}
.skill-sphere-canvas {
    width: 100%; max-width: 500px; height: 300px; pointer-events: none;
}
.skills-sphere-center {
    position: absolute; display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: var(--text-3); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px;
}
.skills-sphere-center i { font-size: 1.4rem; color: var(--accent); }

.skills-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
}
.skill-card {
    position: relative; padding: clamp(24px, 3vw, 32px);
    border-radius: var(--radius-lg); border: 1px solid var(--border);
    background: var(--bg-card); overflow: hidden;
    transition: all 0.4s var(--ease);
}
.skill-card:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateY(-4px); box-shadow: var(--shadow-card); }
.skill-card-header {
    display: flex; align-items: center; gap: 14px; margin-bottom: 20px;
}
.skill-card-icon {
    width: 44px; height: 44px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 1.05rem; color: var(--accent); flex-shrink: 0;
}
.skill-icon-cyan { background: rgba(34,211,238,0.08); color: var(--cyan); }
.skill-icon-emerald { background: rgba(52,211,153,0.08); color: var(--emerald); }
.skill-icon-amber { background: rgba(251,191,36,0.08); color: var(--amber); }
.skill-card-header h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text); }
.skill-card-header span { font-size: 0.72rem; color: var(--text-3); display: block; margin-top: 1px; }

/* Skill Tags */
.skill-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
.skill-tag {
    display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px;
    border-radius: var(--radius-full); font-size: 0.72rem; font-weight: 500;
    background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    color: var(--text-2); transition: all 0.3s var(--ease);
    cursor: default; position: relative;
}
.skill-tag:hover { background: rgba(129,140,248,0.08); border-color: rgba(129,140,248,0.2); color: var(--text); }
.skill-tag i { font-size: 0.8rem; }

/* Skill Bars */
.skill-bars { display: flex; flex-direction: column; gap: 12px; }
.skill-bar-info { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 0.75rem; color: var(--text-2); font-weight: 500; }
.skill-bar-track {
    width: 100%; height: 5px; border-radius: 5px; background: rgba(255,255,255,0.04);
    overflow: hidden;
}
.skill-bar-fill {
    height: 100%; border-radius: 5px; background: var(--gradient);
    width: 0; transition: width 1.2s var(--ease); position: relative;
}
.skill-bar-fill::after {
    content: ''; position: absolute; right: 0; top: -1px; width: 7px; height: 7px;
    border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px rgba(129,140,248,0.5);
    opacity: 0; transition: opacity 0.3s var(--ease);
}
.skill-bar-fill.animated::after { opacity: 1; }
.skill-fill-purple { background: linear-gradient(90deg, var(--accent), var(--purple)); }
.skill-fill-purple::after { background: var(--purple); box-shadow: 0 0 10px rgba(192,132,252,0.5); }
.skill-fill-cyan { background: linear-gradient(90deg, var(--accent), var(--cyan)); }
.skill-fill-cyan::after { background: var(--cyan); box-shadow: 0 0 10px rgba(34,211,238,0.5); }
.skill-fill-emerald { background: linear-gradient(90deg, var(--cyan), var(--emerald)); }
.skill-fill-emerald::after { background: var(--emerald); box-shadow: 0 0 10px rgba(52,211,153,0.5); }
.skill-fill-amber { background: linear-gradient(90deg, var (--emerald), var(--amber)); }
.skill-fill-amber::after { background: var(--amber); box-shadow: 0 0 10px rgba(251,191,36,0.5); }
.skill-fill-rose { background: linear-gradient(90deg, var(--amber), var(--rose)); }
.skill-fill-rose::after { background: var(--rose); box-shadow: 0 0 10px rgba(251,113,133,0.5); }

.skill-card-shine {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.03) 50%, transparent 60%);
    background-size: 200% 200%; transition: background-position 0.8s var(--ease);
}
.skill-card:hover .skill-card-shine { background-position: 100% 100%; }

/* ==================== EXPERIENCE ==================== */
.exp-showcase {}
.exp-card {
    display: flex; gap: 28px; padding: clamp(28px, 4vw, 40px);
    border-radius: var (--radius-lg); border: 1px solid var(--border);
    background: var(--bg-card); transition: all 0.4s var(--ease);
}
.exp-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-card); }
.exp-card-left {
    display: flex; flex-direction: column; align-items: center; gap: 0; flex-shrink: 0;
}
.exp-company-logo {
    width: 72px;
    height: 72px;
    border-radius: var(--radius);
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: visible;
    border: 1px solid var(--border);
}
.exp-logo-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    border-radius: var(--radius-sm);
    position: relative;
    z-index: 2;
}
.exp-logo-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px dashed rgba(129,140,248,0.15);
    animation: holoRing 12s linear infinite;
    z-index: 0;
}
.exp-logo-particle {
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(129,140,248,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5rem;
    color: var(--accent);
    z-index: 3;
    animation: expParticleOrbit 6s linear infinite;
    border: 1px solid rgba(129,140,248,0.15);
}
.exp-logo-p1 { top: -10px; right: -10px; animation-delay: 0s; }
.exp-logo-p2 { bottom: -10px; left: -10px; animation-delay: 2s; }
.exp-logo-p3 { top: 50%; right: -14px; transform: translateY(-50%); animation-delay: 4s; }
@keyframes expParticleOrbit {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-6px) scale(1.2); opacity: 1; }
}
.exp-timeline-line {
    width: 2px; flex: 1; min-height: 30px; margin-top: 8px;
    background: linear-gradient(180deg, var(--accent) 0%, transparent 100%);
    border-radius: 2px;
}
.exp-card-right { flex: 1; min-width: 0; }
.exp-header {
    display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;
    margin-bottom: 20px; flex-wrap: wrap;
}
.exp-header h3 { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--text); }
.exp-company { font-size: 0.88rem; color: var(--accent); font-weight: 500; display: block; margin-top: 2px; }
.exp-duration {
    font-size: 0.75rem; color: var(--text-3); font-weight: 500;
    display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px;
    border-radius: var(--radius-full); background: rgba(255,255,255,0.03);
    border: 1px solid var(--border); white-space: nowrap;
}
.exp-duration i { font-size: 0.7rem; }

/* Experience Metrics */
.exp-metrics {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px;
}
.exp-metric {
    padding: 14px; border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: rgba(255,255,255,0.01); text-align: center;
    transition: all 0.3s var(--ease);
}
.exp-metric:hover { border-color: var(--border-hover); background: rgba(129,140,248,0.04); }
.exp-metric-num {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 800;
    background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    display: block; margin-bottom: 2px;
}
.exp-metric-label { font-size: 0.68rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }

/* Experience List */
.exp-list {
    list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px;
}
.exp-list li {
    font-size: 0.88rem; color: var(--text-2); line-height: 1.7; padding-left: 20px;
    position: relative;
}
.exp-list li::before {
    content: '▸'; position: absolute; left: 0; color: var(--accent); font-weight: 600;
}
.exp-list li strong { color: var(--text); font-weight: 600; }

/* Experience Tags */
.exp-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.exp-tags span {
    padding: 4px 12px; border-radius: var(--radius-full); font-size: 0.7rem; font-weight: 500;
    background: rgba(129,140,248,0.06); border: 1px solid rgba(129,140,248,0.1);
    color: var (--text-2);
}

/* ==================== PROJECTS ==================== */
.project-featured {
    display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 0;
    border-radius: var(--radius-lg); border: 1px solid var(--border);
    background: var(--bg-card); overflow: hidden; margin-bottom: 32px;
    transition: all 0.4s var(--ease);
}
.project-featured:hover { border-color: var(--border-hover); box-shadow: var(--shadow-glow); }

.project-featured-visual {
    padding: clamp(20px, 3vw, 32px); background: rgba(255,255,255,0.01);
    display: flex; align-items: center; justify-content: center;
}
.project-browser {
    width: 100%; border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: rgba(0,0,0,0.3); overflow: hidden;
}
.browser-bar {
    display: flex; align-items: center; gap: 12px; padding: 10px 14px;
    background: rgba(255,255,255,0.03); border-bottom: 1px solid var(--border);
}
.browser-dots { display: flex; gap: 6px; }
.browser-dots span {
    width: 10px; height: 10px; border-radius: 50%;
}
.browser-dots span:nth-child(1) { background: #ff5f57; }
.browser-dots span:nth-child(2) { background: #febc2e; }
.browser-dots span:nth-child(3) { background: #28c840; }
.browser-url {
    flex: 1; font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-3);
    display: flex; align-items: center; gap: 6px; padding: 4px 10px;
    background: rgba(255,255,255,0.02); border-radius: var(--radius-sm);
}
.browser-url i { font-size: 0.55rem; color: var (--emerald); }
.project-illustration {
    padding: 20px; display: flex; align-items: center; justify-content: center;
    min-height: 250px;
}
.project-svg { width: 100%; max-width: 100%; height: auto; }

.project-featured-content {
    padding: clamp(28px, 4vw, 40px); display: flex; flex-direction: column;
    justify-content: center;
}
.project-label {
    display: inline-flex; align-items: center; gap: 8px; font-size: 0.72rem;
    font-weight: 600; color: var(--amber); margin-bottom: 14px;
    text-transform: uppercase; letter-spacing: 1px;
}
.project-label i { font-size: 0.7rem; }
.project-featured-content h3 {
    font-family: var(--font-display); font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 700; color: var (--text); margin-bottom: 16px; line-height: 1.3;
}
.project-desc-box {
    padding: 16px; border-radius: var(--radius-sm); border-left: 3px solid var(--accent);
    background: rgba(129,140,248,0.04); margin-bottom: 20px;
}
.project-desc-box p { font-size: 0.88rem; color: var(--text-2); line-height: 1.75; }
.project-desc-box p strong { color: var(--text); font-weight: 600; }

/* Project KPIs */
.project-kpis {
    display: flex; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;
}
.project-kpi {
    padding: 10px 16px; border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: rgba(255,255,255,0.02); text-align: center; flex: 1; min-width: 70px;
}
.kpi-val {
    font-family: var(--font-display); font-size: 1rem; font-weight: 800; display: block;
    background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.kpi-label { font-size: 0.62rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }

/* Project Stack Tags */
.project-stack { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
.project-stack span {
    padding: 4px 10px; border-radius: var(--radius-full); font-size: 0.68rem;
    font-weight: 500; background: rgba(129,140,248,0.06); border: 1px solid rgba(129,140,248,0.1);
    color: var(--text-2);
}

/* Project Cards Grid */
.projects-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;
}
.project-card {
    border-radius: var(--radius-lg); border: 1px solid var(--border);
    background: var(--bg-card); overflow: hidden;
    transition: all 0.4s var(--ease); position: relative;
}
.project-card:hover { border-color: var(--border-hover); transform: translateY(-6px); box-shadow: var(--shadow-card); }
.project-card-body { padding: clamp(24px, 3vw, 32px); }
.project-card-top {
    display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 18px;
}
.project-card-icon {
    width: 44px; height: 44px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; color: var(--accent);
}
.project-icon-rose { background: rgba(251,113,133,0.08); color: var(--rose); }
.project-card-link {
    width: 36px; height: 36px; border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    color: var(--text-3); font-size: 0.95rem;
    transition: all 0.3s var(--ease);
}
.project-card-link:hover { color: var(--accent); transform: translateY(-2px); }
.project-card-body h3 {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 700;
    color: var(--text); margin-bottom: 10px;
}
.project-card-body p { font-size: 0.85rem; color: var(--text-2); line-height: 1.7; margin-bottom: 16px; }
.project-card-body p strong { color: var(--text); font-weight: 600; }

/* Project Card Images */
.project-card-img {
    position: relative;
    overflow: hidden;
    height: 200px;
}
.project-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
}
.project-card:hover .project-card-img img {
    transform: scale(1.08);
}
.project-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(3,0,20,0.8) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: rgba(255,255,255,0.15);
    transition: all 0.4s var(--ease);
}
.project-card:hover .project-card-img-overlay {
    background: linear-gradient(180deg, transparent 30%, rgba(3,0,20,0.9) 100%);
}
.project-card-img-overlay i {
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.4s var(--ease-bounce);
}
.project-card:hover .project-card-img-overlay i {
    opacity: 0.4;
    transform: scale(1);
}

/* Featured project cover */
.project-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
    min-height: 220px;
}
.project-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(129,140,248,0.1) 0%, rgba(3,0,20,0.6) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
}
.project-img-particles {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
}
.p-particle {
    padding: 4px 10px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,0.1);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    border: 1px solid rgba(255,255,255,0.1);
    animation: floatParticle 3s ease-in-out infinite;
}
.p-particle:nth-child(2) { animation-delay: 0.5s; }
.p-particle:nth-child(3) { animation-delay: 1s; }
@keyframes floatParticle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}
.project-illustration {
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 250px;
    position: relative;
    overflow: hidden;
}

/* ==================== ACHIEVEMENTS ==================== */
.ach-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;
}
.ach-card {
    position: relative; display: flex; align-items: center; gap: 20px;
    padding: clamp(20px, 3vw, 28px); border-radius: var(--radius-lg);
    border: 1px solid var(--border); background: var(--bg-card);
    overflow: hidden; transition: all 0.4s var(--ease);
}
.ach-card:hover { border-color: var(--border-hover); transform: translateY(-4px); box-shadow: var(--shadow-card); }
.ach-card-bg {
    position: absolute; inset: 0; opacity: 0;
    background: linear-gradient(135deg, rgba(129,140,248,0.04) 0%, transparent 70%);
    transition: opacity 0.4s var(--ease); pointer-events: none;
}
.ach-bg-emerald { background: linear-gradient(135deg, rgba(52,211,153,0.04) 0%, transparent 70%); }
.ach-bg-amber { background: linear-gradient(135deg, rgba(251,191,36,0.04) 0%, transparent 70%); }
.ach-bg-purple { background: linear-gradient(135deg, rgba(192,132,252,0.04) 0%, transparent 70%); }
.ach-card:hover .ach-card-bg { opacity: 1; }
.ach-icon {
    width: 52px; height: 52px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; color: var(--accent); flex-shrink: 0;
    transition: transform 0.3s var(--ease-bounce);
}
.ach-card:hover .ach-icon { transform: scale(1.1); }
.ach-icon-indigo { background: rgba(129,140,248,0.08); color: var(--accent); }
.ach-icon-emerald { background: rgba(52,211,153,0.08); color: var(--emerald); }
.ach-icon-amber { background: rgba(251,191,36,0.08); color: var(--amber); }
.ach-icon-purple { background: rgba(192,132,252,0.08); color: var(--purple); }
.ach-body { flex: 1; min-width: 0; position: relative; z-index: 1; }
.ach-body h3 { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.ach-stat {
    font-family: var (--font-display); font-size: 1.4rem; font-weight: 800;
    background: var (--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin-bottom: 4px;
}
.ach-stat span { font-size: 0.9rem; }
.ach-body p { font-size: 0.8rem; color: var(--text-2); line-height: 1.6; }
.ach-body p strong { color: var(--text); font-weight: 600; }
.ach-link {
    position: relative; z-index: 1; font-size: 0.72rem; font-weight: 600;
    color: var(--accent); display: inline-flex; align-items: center; gap: 6px;
    white-space: nowrap; padding: 6px 12px; border-radius: var(--radius-full);
    background: rgba(129,140,248,0.06); border: 1px solid rgba(129,140,248,0.12);
    transition: all 0.3s var(--ease); flex-shrink: 0;
}
.ach-link:hover { background: rgba(129,140,248,0.12); border-color: rgba(129,140,248,0.25); color: var(--accent); }
.edu-score strong {
    color: var(--emerald); font-weight: 700;
}

/* Achievement Categories */
.ach-category {
    margin-bottom: 40px;
}
.ach-category:last-child {
    margin-bottom: 0;
}
.ach-category-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
}
.ach-category-title i {
    color: var(--accent);
    font-size: 1rem;
}

/* Lightning animation */
.ach-lightning-container {
    position: relative;
    display: inline-flex;
    gap: 10px;
    margin-top: 16px;
    justify-content: center;
}
.ach-lightning {
    width: 30px;
    height: 40px;
    filter: drop-shadow(0 0 8px rgba(251,191,36,0.6));
    animation: lightningFlash 3s ease-in-out infinite;
}
.ach-lightning-2 {
    animation-delay: 1.5s;
    width: 24px;
    height: 32px;
    filter: drop-shadow(0 0 8px rgba(129,140,248,0.6));
}
@keyframes lightningFlash {
    0%, 100% { opacity: 0.3; transform: scale(0.95); }
    10% { opacity: 1; transform: scale(1.1); }
    20% { opacity: 0.2; transform: scale(0.98); }
    30% { opacity: 0.9; transform: scale(1.05); }
    40% { opacity: 0.4; transform: scale(1); }
    50%, 100% { opacity: 0.3; transform: scale(0.95); }
}

/* Certificates */
.certs-section {}
.certs-title {
    font-family: var(--font-display); font-size: 1.2rem; font-weight: 700;
    color: var (--text); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;
}
.certs-title i { color: var(--amber); }
.certs-list { display: flex; flex-direction: column; gap: 12px; }
.cert-item {
    display: flex; align-items: center; gap: 16px; padding: 16px 20px;
    border-radius: var(--radius); border: 1px solid var(--border);
    background: var(--bg-card); transition: all 0.3s var(--ease);
    text-decoration: none; color: inherit;
}
.cert-item:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateX(4px); }
.cert-icon {
    width: 40px; height: 40px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 1rem; color: var(--accent); flex-shrink: 0;
}
.cert-icon-cyan { background: rgba(34,211,238,0.08); color: var(--cyan); }
.cert-icon-amber { background: rgba(251,191,36,0.08); color: var(--amber); }
.cert-info { flex: 1; min-width: 0; }
.cert-info strong { font-size: 0.88rem; color: var(--text); font-weight: 600; display: block; }
.cert-info span { font-size: 0.75rem; color: var(--text-3); }
.cert-badge {
    font-size: 0.68rem; font-weight: 600; color: var(--emerald);
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: var(--radius-full);
    background: rgba(52,211,153,0.06); border: 1px solid rgba(52,211,153,0.1);
    white-space: nowrap; flex-shrink: 0;
}
.cert-badge i { font-size: 0.6rem; }

/* Certificate Cards */
.certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 16px;
}
.cert-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: all 0.4s var(--ease);
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
}
.cert-card:hover {
    border-color: rgba(129,140,248,0.3);
    background: var(--bg-card-hover);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(129,140,248,0.1);
    color: inherit;
}
.cert-card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 30%, rgba(129,140,248,0.04), transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
}
.cert-card:hover .cert-card-glow { opacity: 1; }
.cert-card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--accent);
    flex-shrink: 0;
    transition: transform 0.3s var(--ease-bounce);
}
.cert-card:hover .cert-card-icon { transform: scale(1.1); }
.cert-card-cyan .cert-card-icon { background: rgba(34,211,238,0.08); color: var(--cyan); }
.cert-card-amber .cert-card-icon { background: rgba(251,191,36,0.08); color: var(--amber); }
.cert-card-body {
    flex: 1;
    min-width: 0;
}
.cert-card-body h4 {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
    line-height: 1.3;
}
.cert-card-body span {
    font-size: 0.72rem;
    color: var(--text-3);
}
.cert-card-badge {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--emerald);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    border-radius: var(--radius-full);
    background: rgba(52,211,153,0.06);
    border: 1px solid rgba(52,211,153,0.1);
    white-space: nowrap;
    flex-shrink: 0;
}
.cert-card-arrow {
    font-size: 0.7rem;
    color: var(--text-3);
    flex-shrink: 0;
    transition: all 0.3s var(--ease);
    opacity: 0;
    transform: translateX(-4px);
}
.cert-card:hover .cert-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
}

/* ==================== EDUCATION APPLE-STYLE ==================== */
.edu-timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: 700px;
    margin: 0 auto;
}
.edu-timeline::before {
    content: '';
    position: absolute;
    left: 28px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--accent) 0%, var(--purple) 50%, var(--cyan) 100%);
    opacity: 0.15;
    border-radius: 2px;
}
.edu-item {
    position: relative;
    padding-left: 72px;
}
.edu-marker {
    position: absolute;
    left: 16px;
    top: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
}
.edu-marker-dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}
.edu-marker-ping {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    animation: pingDot 2s ease-in-out infinite;
}
.edu-item-primary .edu-marker-dot {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(129,140,248,0.4);
}
.edu-marker-icon {
    margin-top: 8px;
    font-size: 0.75rem;
    color: var(--text-3);
    opacity: 0.6;
}
.edu-card-apple {
    padding: 28px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: all 0.4s var(--ease);
    position: relative;
    overflow: hidden;
}
.edu-card-apple::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient);
    opacity: 0;
    transition: opacity 0.4s var(--ease);
}
.edu-card-apple:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
}
.edu-card-apple:hover::before { opacity: 1; }
.edu-date {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 10px;
    font-family: var(--font-mono);
}
.edu-date i { font-size: 0.65rem; }
.edu-degree {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
}
.edu-field {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-2);
    margin-bottom: 8px;
}
.edu-institution {
    font-size: 0.8rem;
    color: var (--text-3);
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 14px;
}
.edu-institution i { font-size: 0.7rem; color: var(--accent); }
.edu-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.edu-highlights span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 500;
    background: rgba(129,140,248,0.06);
    border: 1px solid rgba(129,140,248,0.1);
    color: var(--text-2);
}
.edu-highlights span i { font-size: 0.65rem; color: var(--accent); }

/* Education Score Ring */
.edu-score-badge {
    position: absolute;
    top: 20px;
    right: 20px;
}
.edu-score-ring {
    position: relative;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.edu-score-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}
.edu-score-path {
    transition: stroke-dasharray 1.5s var(--ease);
}
.edu-score-num {
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text);
}

/* ==================== CONTACT ==================== */
.contact-hero {
    text-align: center; margin-bottom: var(--space-lg);
}
.contact-hero h3 {
    font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 700; color: var(--text); margin-bottom: 10px;
}
.contact-hero p { font-size: clamp(0.88rem, 1.5vw, 1rem); color: var (--text-2); }

.contact-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px, 4vw, 48px); align-items: start;
}

/* Contact Links */
.contact-links { display: flex; flex-direction: column; gap: 12px; }
.contact-row {
    display: flex; align-items: center; gap: 16px; padding: 18px 20px;
    border-radius: var (--radius); border: 1px solid var(--border);
    background: var(--bg-card); transition: all 0.3s var(--ease);
    text-decoration: none; color: inherit;
}
.contact-row:hover { border-color: var(--border-hover); background: var(--bg-card-hover); transform: translateX(6px); }
.contact-row-icon {
    width: 42px; height: 42px; border-radius: var(--radius-sm);
    background: rgba(129,140,248,0.08); display: flex; align-items: center; justify-content: center;
    font-size: 0.95rem; color: var(--accent); flex-shrink: 0;
}
.contact-icon-cyan { background: rgba(34,211,238,0.08); color: var(--cyan); }
.contact-icon-blue { background: rgba(59,130,246,0.08); color: #3b82f6; }
.contact-icon-purple { background: rgba(192,132,252,0.08); color: var(--purple); }
.contact-row-info { flex: 1; min-width: 0; }
.contact-row-info span { font-size: 0.68rem; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; display: block; }
.contact-row-info strong { font-size: 0.88rem; color: var(--text); font-weight: 600; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.contact-row-arrow { font-size: 0.7rem; color: var(--text-3); transition: all 0.3s var(--ease); flex-shrink: 0; }
.contact-row:hover .contact-row-arrow { color: var(--accent); transform: translate(3px, -3px); }

/* Contact Form */
.contact-form-wrap {
    position: relative;
}
.contact-form {
    display: flex; flex-direction: column; gap: 20px;
    padding: clamp(24px, 3vw, 36px); border-radius: var(--radius-lg);
    border: 1px solid var(--border); background: var(--bg-card);
}
.form-group {
    position: relative;
}
.form-group input, .form-group textarea {
    width: 100%; padding: 14px 16px; padding-top: 22px;
    background: rgba(255,255,255,0.03); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text);
    font-family: var(--font); font-size: 0.88rem; font-weight: 400;
    transition: all 0.3s var(--ease); outline: none; resize: vertical;
}
.form-group input:focus, .form-group textarea:focus {
    border-color: var(--accent); background: rgba(129,140,248,0.03);
}
.form-group label {
    position: absolute; top: 18px; left: 16px;
    font-size: 0.82rem; color: var(--text-3); font-weight: 500;
    pointer-events: none; transition: all 0.3s var(--ease);
}
.form-group input:focus ~ label,
.form-group input:not(:placeholder-shown) ~ label,
.form-group textarea:focus ~ label,
.form-group textarea:not(:placeholder-shown) ~ label {
    top: 6px; font-size: 0.62rem; color: var(--accent); letter-spacing: 0.5px;
}
.form-line {
    position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
    background: var(--gradient); transform: scaleX(0);
    transition: transform 0.4s var(--ease); border-radius: 0 0 var(--radius-sm) var(--radius-sm);
}
.form-group input:focus ~ .form-line,
.form-group textarea:focus ~ .form-line {
    transform: scaleX(1);
}
.form-error {
    display: none; font-size: 0.72rem; color: var(--rose); margin-top: 6px;
    align-items: center; gap: 5px;
}
.form-group.error .form-error { display: flex; }
.form-group.error input, .form-group.error textarea { border-color: var(--rose); }
.form-char-count {
    position: absolute; bottom: 8px; right: 12px;
    font-size: 0.65rem; color: var(--text-3); font-family: var(--font-mono);
}

.form-success {
    display: none; text-align: center; padding: 40px;
    border-radius: var(--radius-lg); border: 1px solid rgba(52,211,153,0.2);
    background: rgba(52,211,153,0.04);
}
.form-success.visible { display: block; }
.form-success i { font-size: 2.5rem; color: var(--emerald); margin-bottom: 16px; display: block; }
.form-success p { font-size: 1rem; color: var(--text); font-weight: 600; }

/* Contact WhatsApp Button */
.btn-whatsapp {
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%) !important;
    box-shadow: 0 4px 20px rgba(37,211,102,0.3);
}
.btn-whatsapp:hover {
    box-shadow: 0 8px 40px rgba(37,211,102,0.45) !important;
}
.contact-form-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    background: rgba(37,211,102,0.06);
    border: 1px solid rgba(37,211,102,0.12);
    border-radius: var(--radius) var(--radius) 0 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: #25d366;
    margin-bottom: -1px;
}
.contact-form-header i {
    font-size: 1.1rem;
}
.contact-icon-green {
    background: rgba(37,211,102,0.08);
    color: #25d366;
}
.contact-row-whatsapp:hover {
    border-color: rgba(37,211,102,0.3);
    background: rgba(37,211,102,0.04);
}
.contact-cv-row {
    display: flex;
    gap: 12px;
    margin-top: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
}

/* ==================== FOOTER ==================== */
.footer {
    padding: var(--space-xl) 0 var(--space-lg);
    background: var(--bg-2); position: relative;
}
.footer-gradient-line {
    width: 100%; height: 2px; background: var(--gradient); margin-bottom: var(--space-lg);
    border-radius: 2px; opacity: 0.5;
}
.footer-grid {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 40px;
    align-items: start; margin-bottom: var(--space-lg);
}
.footer-brand {
    display: flex; flex-direction: column; gap: 12px;
}
.footer-brand span {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--text);
}
.footer-brand p { font-size: 0.85rem; color: var(--text-2); max-width: 280px; line-height: 1.7; }
.footer-links {
    display: flex; flex-direction: column; gap: 10px;
}
.footer-links a {
    font-size: 0.85rem; color: var(--text-2); font-weight: 500;
    transition: all 0.3s var(--ease);
}
.footer-links a:hover { color: var(--accent); transform: translateX(4px); }
.footer-social {
    display: flex; gap: 10px; flex-wrap: wrap;
}
.footer-social a {
    width: 40px; height: 40px; border-radius: var(--radius-sm);
    background: rgba(255,255,255,0.03); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-2); font-size: 0.9rem;
    transition: all 0.3s var(--ease);
}
.footer-social a:hover { background: rgba(129,140,248,0.08); border-color: rgba(129,140,248,0.2); color: var(--accent); transform: translateY(-3px); }
.footer-bottom {
    text-align: center; padding-top: var(--space-md);
    border-top: 1px solid var(--border);
}
.footer-bottom p { font-size: 0.8rem; color: var(--text-3); }
.footer-bottom strong { color: var(--text-2); }
.footer-heart { color: var(--rose); font-size: 0.9rem; animation: heartBeat 1.5s ease-in-out infinite; display: inline-block; }
@keyframes heartBeat { 0%,100% { transform: scale(1); } 50% { transform: scale(1.2); } }
.footer-tagline { font-size: 0.7rem; color: var(--text-3); margin-top: 6px; font-style: italic; }

/* ==================== BACK TO TOP — PROGRESS RING ==================== */
.back-to-top svg {
    position: absolute; inset: 0; width: 100%; height: 100%;
    transform: rotate(-90deg);
}
.progress-ring-circle {
    fill: none; stroke: var(--accent); stroke-width: 2;
    stroke-dasharray: 138.23; stroke-dashoffset: 138.23;
    transition: stroke-dashoffset 0.2s linear;
}
.back-to-top i { position: relative; z-index: 2; }

/* ==================== CARD GLOW OVERLAY ==================== */
.value-card::before, .skill-card::before, .project-card::before, .ach-card::before {
    content: ''; position: absolute; inset: 0; border-radius: inherit;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
        rgba(129,140,248,0.06), transparent 40%);
    opacity: 0; transition: opacity 0.3s var(--ease); pointer-events: none;
}
.value-card:hover::before, .skill-card:hover::before, .project-card:hover::before, .ach-card:hover::before {
    opacity: 1;
}

/* ==================== MOBILE NAV (RESPONSIVE) ==================== */
@media (max-width: 768px) {
    .nav-links {
        position: fixed; top: 0; right: 0; width: 280px; height: 100vh; height: 100dvh;
        background: rgba(3,0,20,0.95); -webkit-backdrop-filter: blur(24px);
        backdrop-filter: blur(24px);
        flex-direction: column; align-items: stretch; justify-content: center;
        padding: 80px 32px 40px; gap: 4px;
        transform: translateX(100%); transition: transform 0.5s var(--ease);
        z-index: 1000; border-left: 1px solid var(--border);
    }
    .nav-links.active { transform: translateX(0); }
    .nav-burger { display: flex; }
    .nav-link {
        font-size: 1rem; padding: 14px 16px; border-radius: var(--radius-sm);
        transition: background 0.3s var(--ease), color 0.3s var(--ease);
    }
    .nav-link:hover { background: rgba(129,140,248,0.06); }
    .nav-link::after { display: none; }
    .nav-link-cta { margin-left: 0; margin-top: 12px; justify-content: center; }

    [data-theme="light"] .nav-links {
        background: rgba(248,247,252,0.96);
    }

    .mobile-fab { display: flex; }

    .cursor, .cursor-follower { display: none !important; }
    .hero-content { grid-template-columns: 1fr; text-align: center; }
    .hero-text { order: 2; }
    .hero-visual { order: 1; margin-bottom: 20px; }
    .hero-photo-container { width: clamp(200px, 55vw, 260px); height: clamp(200px, 55vw, 260px); }
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-cta { justify-content: center; }
    .hero-badge { margin-left: auto; margin-right: auto; }
    .hero-subtitle { margin-left: auto; margin-right: auto; }
    .hero-terminal { margin-left: auto; margin-right: auto; }
    .hero-tagline { text-align: center; }

    /* Hide HUDs on mobile — too small */
    .hero-hud { display: none; }
    .hero-hologram-ring-3 { display: none; }

    .about-grid { grid-template-columns: 1fr; }
    .about-photo-wrap { max-width: 280px; margin-bottom: 20px; }
    .about-exp-badge { left: auto; right: 10px; bottom: 10px; }

    .value-cards { grid-template-columns: 1fr 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .projects-grid { grid-template-columns: 1fr; }
    .project-featured { grid-template-columns: 1fr; }
    .project-featured-content { padding: clamp(20px, 3vw, 28px); }
    .project-featured-visual { padding: 16px; }
    .ach-grid { grid-template-columns: 1fr; }
    .ach-card { flex-wrap: wrap; }
    .contact-grid { grid-template-columns: 1fr; }
    .footer-grid { grid-template-columns: 1fr; text-align: center; }
    .footer-brand p { margin: 0 auto; }
    .footer-social { justify-content: center; }
    .footer-links { align-items: center; }

    .hero-scroll { display: none; }
    .scroll-mascot { display: none; }
    .kbd-hint { display: none !important; }

    .about-info-grid { grid-template-columns: 1fr; }
    .exp-card { flex-direction: column; }
    .exp-card-left { flex-direction: row; align-items: center; }
    .exp-timeline-line { width: auto; height: 2px; flex: 1; }
    .exp-metrics { grid-template-columns: repeat(3, 1fr); }
    .nikhil-bot { display: none; }
    .certs-grid { grid-template-columns: 1fr; }
    .edu-timeline::before { left: 20px; }
    .edu-item { padding-left: 58px; }
    .edu-marker { left: 8px; }
    .edu-score-badge { position: relative; top: auto; right: auto; margin-top: 14px; }
    .hero-social { justify-content: center; }
    .contact-cv-row { flex-direction: column; }
    .ach-lightning-container { display: none; }
    .tagline-rotate-wrap { min-width: 160px; }
}

@media (max-width: 480px) {
    .value-cards { grid-template-columns: 1fr; }
    .hero-stats { flex-direction: column; gap: 12px; }
    .hero-stat-divider { width: 40px; height: 1px; }
    .exp-metrics { grid-template-columns: 1fr; }
    .hero-photo-container { width: 200px; height: 200px; }
    .photo-badge { width: 30px; height: 30px; font-size: 0.7rem; }
    .hero-title .hero-name { font-size: clamp(1.8rem, 8vw, 2.8rem); }
}

/* ==================== TABLET BREAKPOINT ==================== */
@media (min-width: 769px) and (max-width: 1024px) {
    .hero-content { gap: 30px; }
    .hero-photo-container { width: 240px; height: 240px; }
    .hero-hud { font-size: 0.55rem; padding: 4px 8px; }
    .hero-hud-tl { left: -45px; }
    .hero-hud-tr { right: -45px; }
    .hero-hud-bl { left: -50px; }
    .hero-hud-br { right: -40px; }
    .about-grid { grid-template-columns: 0.6fr 1.4fr; gap: 30px; }
    .value-cards { grid-template-columns: 1fr 1fr; }
}

/* ==================== REDUCED MOTION ==================== */
@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
    .hero-matrix { display: none; }
    .hero-hologram-ring { animation: none; }
    .scroll-mascot { display: none; }
    .sparkle { display: none; }
    .marquee-content { animation: none; }
}

/* ==================== PRINT STYLES ==================== */
@media print {
    .preloader, .cursor, .cursor-follower, .noise, .scroll-progress,
    .back-to-top, .scroll-mascot, .hero-matrix, .hero-neural-bg,
    .hero-canvas, .hero-blob, .hero-grid, .section-glow,
    .nav, .nav-overlay, .mobile-fab, .kbd-hint { display: none !important; }
    body { background: #fff; color: #000; }
    .section { padding: 20px 0; }
    [data-animate] { opacity: 1 !important; transform: none !important; }
}

/* ============================================================
   CHAMBER / ROOM SYSTEM — DESCENDING INTO ROOMS (DISABLED)
   The portfolio now uses lightweight, stable animations only.
   ============================================================ */

/* Disable snap scrolling + chamber transforms/doorways/ambient particles */
html { scroll-snap-type: none !important; scroll-padding-top: 100px !important; }
section.chamber, .hero {
    scroll-snap-align: none !important;
    scroll-snap-stop: normal !important;
}

.chamber,
.chamber.in-view,
.hero,
.hero.in-view,
.doorway,
.doorway.in-view,
.room-ambient,
.room-mini-nikhil,
.depth-indicator,
.doorway-walker {
    animation: none !important;
    transition: none !important;
    transform: none !important;
    opacity: 1 !important;
    filter: none !important;
}

/* Hide room/chamber UI elements completely */
.chamber::before,
.chamber::after,
.doorway,
.room-ambient,
.room-mini-nikhil,
.depth-indicator {
    display: none !important;
}

/* ==================== BACK TO TOP ==================== */
.back-to-top {
    position: fixed; bottom: 28px; right: 28px; z-index: 998;
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(3,0,20,0.8); -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border); display: flex; align-items: center; justify-content: center;
    color: var(--text-2); font-size: 0.9rem; cursor: pointer;
    opacity: 0; visibility: hidden; transform: translateY(20px);
    transition: all 0.4s var(--ease);
}
.back-to-top.visible { opacity: 1; visibility: visible; transform: translateY(0); }
.back-to-top:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-3px); background: rgba(129,140,248,0.08); }
[data-theme="light"] .back-to-top { background: rgba(248,247,252,0.9); }

/* ==================== ANIMATION SYSTEM ==================== */
[data-animate] { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
[data-animate="fade-left"] { transform: translateX(30px); }
[data-animate="fade-right"] { transform: translateX(-30px); }
[data-animate].animated { opacity: 1; transform: translate(0); }

/* ==================== SPARKLE EFFECT ==================== */
.sparkle {
    position: fixed; pointer-events: none; z-index: 9997;
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent); opacity: 0;
    animation: sparkleAnim 0.6s var(--ease) forwards;
}
@keyframes sparkleAnim {
    0% { opacity: 1; transform: scale(0) translateY(0); }
    50% { opacity: 0.8; transform: scale(1.2) translateY(-15px); }
    100% { opacity: 0; transform: scale(0.5) translateY(-30px); }
}

/* ==================== TOASTS ==================== */
.easter-egg-toast, .network-toast {
    position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px);
    padding: 12px 24px; border-radius: var(--radius-full);
    background: rgba(3,0,20,0.9); -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border); z-index: 9999;
    font-size: 0.82rem; font-weight: 500; color: var(--text);
    display: flex; align-items: center; gap: 10px;
    opacity: 0; transition: all 0.5s var(--ease-bounce); pointer-events: none;
}
.easter-egg-toast.visible, .network-toast.visible {
    opacity: 1; transform: translateX(-50%) translateY(0); pointer-events: auto;
}

/* ==================== MOBILE FAB ==================== */
.mobile-fab {
    display: none; position: fixed; bottom: 20px; right: 20px; z-index: 998;
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--gradient); color: #fff; border: none;
    align-items: center; justify-content: center; font-size: 1.1rem;
    box-shadow: 0 4px 20px rgba(129,140,248,0.4); cursor: pointer;
    transition: transform 0.3s var(--ease);
}
.mobile-fab:hover { transform: scale(1.1); }

/* ==================== LIGHT THEME ==================== */
[data-theme="light"] {
    --bg: #f8f7fc;
    --bg-2: #f0eef6;
    --bg-3: #e8e6f0;
    --bg-card: rgba(0,0,0,0.02);
    --bg-card-hover: rgba(0,0,0,0.04);
    --text: #1a1625;
    --text-2: #5a5570;
    --text-3: #8a859d;
    --border: rgba(0,0,0,0.06);
    --border-hover: rgba(0,0,0,0.12);
    --shadow-card: 0 8px 32px rgba(0,0,0,0.08);
}
[data-theme="light"] .hero-name {
    background: linear-gradient(135deg, #1a1625 0%, #6366f1 50%, #a855f7 100%);
    background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
[data-theme="light"] .noise { opacity: 0.008; }
[data-theme="light"] .hero-blob { opacity: 0.06; }
[data-theme="light"] .hero-grid {
    background-image: linear-gradient(rgba(99,102,241,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.04) 1px, transparent 1px);
}
[data-theme="light"] .hero-terminal { background: rgba(0,0,0,0.04); border-color: rgba(0,0,0,0.08); }
[data-theme="light"] .hero-photo { border-color: rgba(99,102,241,0.25); }
[data-theme="light"] .hero-hud { background: rgba(248,247,252,0.85); border-color: rgba(0,0,0,0.08); }
[data-theme="light"] .mascot-speech { background: rgba(248,247,252,0.95); border-color: rgba(0,0,0,0.08); }
[data-theme="light"] .mascot-speech::after { border-top-color: rgba(248,247,252,0.95); }

/* ==================== MINI ME — NIKHIL BOT ==================== */
.nikhil-bot {
    position: fixed;
    left: 24px;
    top: 50%;
    z-index: 997;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-50%) scale(0);
    transition: opacity 0.6s var(--ease-bounce), transform 0.6s var(--ease-bounce);
}
.nikhil-bot.visible {
    opacity: 1;
    transform: translateY(-50%) scale(1);
    pointer-events: auto;
}
.nikhil-bot.walking {
    animation: botWalk 0.4s ease-in-out infinite;
}
@keyframes botWalk {
    0%, 100% { transform: translateY(-50%) scale(1) rotate(0deg); }
    25% { transform: translateY(-50%) scale(1) rotate(-3deg) translateX(-2px); }
    75% { transform: translateY(-50%) scale(1) rotate(3deg) translateX(2px); }
}
.nikhil-bot.celebrating {
    animation: botCelebrate 0.5s var(--ease-bounce) infinite;
}
@keyframes botCelebrate {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(calc(-50% - 10px)) scale(1.1); }
}
.nikhil-bot.thinking {
    animation: botThink 1.5s ease-in-out infinite;
}
@keyframes botThink {
    0%, 100% { transform: translateY(-50%) scale(1) rotate(0deg); }
    25% { transform: translateY(-50%) scale(1) rotate(-5deg); }
    50% { transform: translateY(-50%) scale(1) rotate(0deg); }
    75% { transform: translateY(-50%) scale(1) rotate(5deg); }
}
.nikhil-bot.waving .bot-arm-right {
    animation: armWave 0.5s var(--ease-bounce) infinite;
}
@keyframes armWave {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-45deg); }
}
.nikhil-bot.typing .bot-arm-left,
.nikhil-bot.typing .bot-arm-right {
    animation: armType 0.3s ease-in-out infinite alternate;
}
@keyframes armType {
    0% { transform: rotate(0deg) translateY(0); }
    100% { transform: rotate(-8deg) translateY(-3px); }
}
.nikhil-bot.dancing {
    animation: botDance 0.6s var(--ease-bounce) infinite;
}
@keyframes botDance {
    0%, 100% { transform: translateY(-50%) scale(1) rotate(0deg); }
    25% { transform: translateY(calc(-50% - 6px)) scale(1.05) rotate(-8deg); }
    50% { transform: translateY(-50%) scale(1) rotate(0deg); }
    75% { transform: translateY(calc(-50% - 6px)) scale(1.05) rotate(8deg); }
}
.nikhil-bot.sleeping {
    animation: botSleep 2s ease-in-out infinite;
}
@keyframes botSleep {
    0%, 100% { transform: translateY(-50%) scale(1) rotate(0deg); }
    50% { transform: translateY(-50%) scale(0.95) rotate(5deg); }
}
.nikhil-bot.flexing .bot-arm-right {
    animation: armFlex 0.8s var(--ease-bounce) infinite;
}
.nikhil-bot.flexing .bot-arm-left {
    animation: armFlex 0.8s var(--ease-bounce) 0.2s infinite;
}
@keyframes armFlex {
    0%, 100% { transform: rotate(0deg) scaleY(1); }
    50% { transform: rotate(-30deg) scaleY(1.15); }
}
.nikhil-bot.writing {
    animation: botWriteShake 0.3s ease-in-out infinite;
}
@keyframes botWriteShake {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(-50%) scale(1) translateX(2px); }
}

.bot-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
}

/* Avatar */
.bot-avatar {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: visible;
    z-index: 2;
}
.bot-face {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid rgba(129,140,248,0.5);
    box-shadow: 0 0 12px rgba(129,140,248,0.3), 0 2px 8px rgba(0,0,0,0.4);
    transition: border-color 0.3s var(--ease);
}
.nikhil-bot:hover .bot-face {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(129,140,248,0.5), 0 2px 12px rgba(0,0,0,0.4);
}
.bot-glasses {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 8px;
    pointer-events: none;
    display: none; /* hidden, using real face */
}

/* Antenna */
.nikhil-bot .bot-antenna {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 8px;
    background: rgba(129,140,248,0.5);
    border-radius: 1px;
}
.nikhil-bot .bot-antenna-ball {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cyan);
    position: absolute;
    top: -3px;
    left: -1.5px;
    box-shadow: 0 0 6px rgba(34,211,238,0.7);
    animation: antennaPulse 2s ease-in-out infinite;
}

/* Body */
.bot-body {
    width: 26px;
    height: 14px;
    background: linear-gradient(135deg, rgba(129,140,248,0.2), rgba(192,132,252,0.15));
    border-radius: 0 0 8px 8px;
    margin-top: -2px;
    position: relative;
    border: 1px solid rgba(129,140,248,0.15);
    border-top: none;
}

/* Arms */
.bot-arm {
    position: absolute;
    width: 3px;
    height: 10px;
    background: rgba(129,140,248,0.3);
    border-radius: 2px;
    top: 0;
    transform-origin: top center;
    transition: transform 0.3s var(--ease);
}
.bot-arm-left { left: -5px; }
.bot-arm-right { right: -5px; }

/* Action Icon — floats near the bot */
.bot-action-icon {
    position: absolute;
    top: -6px;
    right: -14px;
    font-size: 0.65rem;
    opacity: 0;
    transform: scale(0) translateY(4px);
    transition: all 0.4s var(--ease-bounce);
    pointer-events: none;
    z-index: 3;
    filter: drop-shadow(0 0 4px rgba(129,140,248,0.5));
}
.bot-action-icon.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
}

/* Speech Bubble */
.bot-speech {
    position: absolute;
    left: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%) translateX(-6px);
    white-space: nowrap;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    background: rgba(3,0,20,0.88);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(129,140,248,0.2);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--text-2);
    opacity: 0;
    transition: all 0.4s var(--ease-bounce);
    pointer-events: none;
    z-index: 4;
}
.bot-speech.visible {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
}
.bot-speech::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-right-color: rgba(3,0,20,0.88);
}
[data-theme="light"] .bot-speech {
    background: rgba(248,247,252,0.95);
    border-color: rgba(0,0,0,0.08);
}
[data-theme="light"] .bot-speech::before {
    border-right-color: rgba(248,247,252,0.95);
}

/* Z-Z-Z floating for sleep mode */
.bot-zzz {
    position: absolute;
    top: -4px;
    right: -18px;
    font-size: 0.55rem;
    font-weight: 800;
    color: var(--accent);
    opacity: 0;
    animation: zzzFloat 2s ease-in-out infinite;
    pointer-events: none;
}
.bot-zzz:nth-child(2) { animation-delay: 0.5s; right: -10px; top: -10px; font-size: 0.45rem; }
.bot-zzz:nth-child(3) { animation-delay: 1s; right: -22px; top: -2px; font-size: 0.4rem; }
@keyframes zzzFloat {
    0% { opacity: 0; transform: translateY(0) scale(0.7); }
    30% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-18px) scale(1); }
}

/* Sweat drops for working hard */
.bot-sweat {
    position: absolute;
    width: 3px;
    height: 5px;
    background: var(--cyan);
    border-radius: 0 0 50% 50%;
    opacity: 0;
    pointer-events: none;
}
.nikhil-bot.typing .bot-sweat,
.nikhil-bot.writing .bot-sweat {
    animation: sweatDrop 1s ease-in-out infinite;
}
@keyframes sweatDrop {
    0% { opacity: 0; transform: translateY(0); }
    20% { opacity: 1; }
    100% { opacity: 0; transform: translateY(12px); }
}
.bot-sweat-1 { top: 8px; right: -4px; animation-delay: 0s; }
.bot-sweat-2 { top: 4px; right: -8px; animation-delay: 0.4s; }

/* Heart burst for contact section */
.bot-hearts {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 3px;
    pointer-events: none;
    opacity: 0;
}
.nikhil-bot.loving .bot-hearts { opacity: 1; }
.bot-hearts span {
    font-size: 0.55rem;
    animation: heartBurst 1s var(--ease-bounce) infinite;
}
.bot-hearts span:nth-child(1) { animation-delay: 0s; }
.bot-hearts span:nth-child(2) { animation-delay: 0.2s; }
.bot-hearts span:nth-child(3) { animation-delay: 0.4s; }
@keyframes heartBurst {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.8; }
    50% { transform: translateY(-10px) scale(1.3); opacity: 1; }
}

/* Trail particles behind bot while moving */
.bot-trail {
    position: fixed;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    pointer-events: none;
    z-index: 996;
    opacity: 0;
    animation: trailFade 0.6s var(--ease) forwards;
}
@keyframes trailFade {
    0% { opacity: 0.6; transform: scale(1); }
    100% { opacity: 0; transform: scale(0); }
}

/* Hide on mobile */
@media (max-width: 768px) {
    .nikhil-bot { display: none !important; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
    .nikhil-bot { display: none !important; }
}

/* ============================================================
   GOD-LEVEL EFFECTS V2 — CHROMATIC | PARTICLES | SHOCKWAVE
   ============================================================ */

/* ==================== CHROMATIC ABERRATION LAYER ==================== */
.chromatic-aberration-layer {
    position: fixed;
    inset: 0;
    z-index: 9995;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s linear;
    mix-blend-mode: screen;
    background:
        linear-gradient(0deg,
            rgba(255, 0, 0, 0.03) 0%,
            transparent 33%,
            rgba(0, 255, 0, 0.02) 33%,
            transparent 66%,
            rgba(0, 100, 255, 0.03) 66%,
            transparent 100%
        );
    background-size: 100% calc(3px + var(--chroma-spread, 0px));
    animation: chromaScan 0.08s linear infinite;
}
@keyframes chromaScan {
    0% { background-position: 0 0; }
    100% { background-position: 0 calc(3px + var(--chroma-spread, 0px)); }
}

/* ==================== CLICK SHOCKWAVE ==================== */
.click-shockwave {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(129, 140, 248, 0.6);
    pointer-events: none;
    z-index: 9997;
    transform: translate(-50%, -50%);
    animation: shockwaveExpand 0.6s var(--ease-out) forwards;
}
@keyframes shockwaveExpand {
    0% {
        width: 10px;
        height: 10px;
        opacity: 1;
        border-width: 2px;
    }
    100% {
        width: 200px;
        height: 200px;
        opacity: 0;
        border-width: 0.5px;
    }
}

/* ==================== CLICK PARTICLES ==================== */
.click-particle {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9997;
    transform: translate(-50%, -50%);
    animation: clickParticleFly 0.55s var(--ease-out) forwards;
    box-shadow: 0 0 6px currentColor;
}
@keyframes clickParticleFly {
    0% {
        opacity: 1;
        transform: translate(-50%, -50%) translate(0, 0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -50%) translate(var(--dx), var(--dy)) scale(0.2);
    }
}

/* ==================== AURORA CURSOR TRAIL ==================== */
.cursor-aurora-trail {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9994;
}
.aurora-dot {
    position: fixed;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    pointer-events: none;
    background: var(--accent);
    opacity: 0;
    will-change: transform, opacity;
    filter: blur(2px);
    mix-blend-mode: screen;
    transition: none;
}
.aurora-dot:nth-child(odd) {
    background: var(--purple);
}
.aurora-dot:nth-child(3n) {
    background: var(--cyan);
}
.aurora-dot:nth-child(4n) {
    background: var(--emerald);
    width: 6px;
    height: 6px;
}

/* ==================== COUNTER SPARK EXPLOSION ==================== */
.counter-spark {
    position: fixed;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    pointer-events: none;
    z-index: 9997;
    transform: translate(-50%, -50%);
    animation: counterSparkFly 0.65s var(--ease-out) forwards;
    box-shadow: 0 0 8px var(--accent);
}
.counter-spark:nth-child(odd) {
    background: var(--cyan);
    box-shadow: 0 0 8px var(--cyan);
}
.counter-spark:nth-child(3n) {
    background: var(--purple);
    box-shadow: 0 0 8px var(--purple);
}
@keyframes counterSparkFly {
    0% {
        opacity: 1;
        transform: translate(-50%, -50%) translate(0, 0) scale(1);
    }
    60% {
        opacity: 0.8;
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -50%) translate(var(--spark-x), var(--spark-y)) scale(0);
    }
}

/* ==================== SECTION ATMOSPHERE OVERLAY ==================== */
.section-atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    transition: background 0.8s var(--ease);
    opacity: 1;
}

/* ==================== SECTION TITLE GLOW ON ENTER ==================== */
.section-title.glow-entered {
    animation: titleGlowPulse 1.2s ease-out forwards;
}
@keyframes titleGlowPulse {
    0% {
        text-shadow: 0 0 0 transparent;
        filter: brightness(1);
    }
    30% {
        text-shadow:
            0 0 20px rgba(129, 140, 248, 0.4),
            0 0 40px rgba(192, 132, 252, 0.2),
            0 0 60px rgba(34, 211, 238, 0.1);
        filter: brightness(1.2);
    }
    100% {
        text-shadow: 0 0 0 transparent;
        filter: brightness(1);
    }
}

/* ==================== VELOCITY BURST CANVAS ==================== */
.velocity-burst-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9996;
}

/* ==================== SCROLL VELOCITY REACTIVE BODY ==================== */
body {
    --scroll-skew: 0deg;
    --scroll-velocity: 0;
    --scroll-squeeze: 1;
}

/* ==================== ENHANCED HOVER EFFECTS ==================== */
.value-card:hover,
.skill-card:hover,
.project-card:hover,
.ach-card:hover,
.cert-card:hover,
.edu-card-apple:hover {
    box-shadow:
        var(--shadow-card),
        0 0 40px rgba(129, 140, 248, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

/* ==================== MOBILE: DISABLE HEAVY EFFECTS ==================== */
@media (max-width: 768px) {
    .chromatic-aberration-layer,
    .velocity-burst-canvas,
    .cursor-aurora-trail,
    .click-shockwave,
    .click-particle,
    .counter-spark {
        display: none !important;
    }
    .section-atmosphere {
        opacity: 0.5;
    }
}

/* ==================== REDUCED MOTION: DISABLE ALL GOD-LEVEL ==================== */
@media (prefers-reduced-motion: reduce) {
    .chromatic-aberration-layer,
    .velocity-burst-canvas,
    .cursor-aurora-trail,
    .click-shockwave,
    .click-particle,
    .counter-spark,
    .section-atmosphere {
        display: none !important;
    }
    .section-title.glow-entered {
        animation: none !important;
    }
}

/* ============================================================
   GOD-LEVEL EFFECTS V3 — IDLE | HOLOGRAM | KONAMI | DOORWAY
   SOUNDWAVE | REPULSION | FOG | BREATHING | CHARACTER WAVE
   ============================================================ */

/* ==================== IDLE AMBIENT PARTICLES ==================== */
.idle-particle {
    position: fixed;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    animation: idleParticleFloat 6s ease-in-out infinite;
}
.idle-particle:nth-child(odd) {
    background: var(--purple);
    box-shadow: 0 0 6px var(--purple);
    width: 2px;
    height: 2px;
}
.idle-particle:nth-child(3n) {
    background: var(--cyan);
    box-shadow: 0 0 6px var (--cyan);
}
@keyframes idleParticleFloat {
    0% {
        opacity: 0;
        transform: translateY(0) translateX(0) scale(0.5);
    }
    15% {
        opacity: 0.6;
    }
    85% {
        opacity: 0.4;
    }
    100% {
        opacity: 0;
        transform: translateY(-80px) translateX(var(--idle-dx, 20px)) scale(0);
    }
}

/* ==================== HOLOGRAM FLICKER ON HERO PHOTO ==================== */
.hero-photo.hologram-flicker {
    animation: holoFlicker 0.15s steps(2) 3;
}
@keyframes holoFlicker {
    0% { opacity: 1; filter: brightness(1) hue-rotate(0deg); }
    25% { opacity: 0.7; filter: brightness(1.4) hue-rotate(10deg); }
    50% { opacity: 0.9; filter: brightness(0.8) hue-rotate(-5deg); }
    75% { opacity: 0.6; filter: brightness(1.6) hue-rotate(15deg); }
    100% { opacity: 1; filter: brightness(1) hue-rotate(0deg); }
}

/* ==================== DOORWAY PORTAL RIPPLE ==================== */
.doorway-portal-ripple {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(129, 140, 248, 0.5);
    pointer-events: none;
    z-index: 10;
    transform: translate(-50%, -50%);
    animation: portalRippleExpand 1s var(--ease-out) forwards;
}
@keyframes portalRippleExpand {
    0% {
        width: 10px;
        height: 10px;
        opacity: 1;
        border-width: 2px;
    }
    100% {
        width: 250px;
        height: 250px;
        opacity: 0;
        border-width: 0.5px;
    }
}

/* ==================== ENERGY PULSE DOT ON SECTION LINES ==================== */
.section-line {
    position: relative;
    overflow: visible;
}
.energy-pulse-dot {
    position: absolute;
    top: 50%;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent), 0 0 20px rgba(129, 140, 248, 0.3);
    transform: translateY(-50%);
    animation: energyPulseDotTravel 2.5s ease-in-out infinite;
    pointer-events: none;
}
@keyframes energyPulseDotTravel {
    0% { left: -6px; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { left: calc(100% + 6px); opacity: 0; }
}

/* ==================== KONAMI CODE FLASH ==================== */
.konami-flash {
    position: fixed;
    inset: 0;
    z-index: 10001;
    pointer-events: none;
    background: white;
    opacity: 0;
    animation: konamiFlash 0.8s ease-out forwards;
}
@keyframes konamiFlash {
    0% { opacity: 0; }
    10% { opacity: 0.8; }
    100% { opacity: 0; }
}

/* ==================== KONAMI FIREWORK ==================== */
.konami-firework {
    position: fixed;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 10002;
    transform: translate(-50%, -50%);
    animation: konamiFireworkBurst 1.2s var(--ease-out) forwards;
}
@keyframes konamiFireworkBurst {
    0% {
        opacity: 1;
        transform: translate(-50%, -50%) translate(0, 0) scale(1);
    }
    40% {
        opacity: 1;
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -50%) translate(var(--fw-x), var(--fw-y)) scale(0);
    }
}

/* ============================================================
   GOD-LEVEL EFFECTS V4 — HOLOGRAPHIC | CONSTELLATION | GLITCH
   SOUNDWAVE | REPULSION | FOG | BREATHING | CHARACTER WAVE
   ============================================================ */

/* ==================== HOLOGRAPHIC RAINBOW SWEEP ==================== */
.holo-rainbow-sweep {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(
        circle at var(--holo-x, 50%) var(--holo-y, 50%),
        rgba(255, 0, 0, 0.04) 0%,
        rgba(255, 165, 0, 0.03) 15%,
        rgba(255, 255, 0, 0.03) 30%,
        rgba(0, 255, 0, 0.03) 45%,
        rgba(0, 200, 255, 0.04) 60%,
        rgba(130, 0, 255, 0.03) 75%,
        transparent 90%
    );
    mix-blend-mode: screen;
    border-radius: inherit;
}

/* ==================== BREATHING BACKGROUND PULSE ==================== */
.breathing-bg-pulse {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -2;
    background: radial-gradient(
        ellipse 80% 60% at 50% 50%,
        rgba(129, 140, 248, 0.015) 0%,
        transparent 70%
    );
    animation: breathingPulse 6s ease-in-out infinite;
}
@keyframes breathingPulse {
    0%, 100% {
        opacity: 0.3;
        transform: scale(1);
    }
    50% {
        opacity: 1;
        transform: scale(1.05);
    }
}

/* ==================== VIEWPORT LIGHT SOURCE ==================== */
.viewport-light-source {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    transition: background 0.1s linear;
}

/* ==================== CONSTELLATION CANVAS ==================== */
.constellation-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
}

/* ==================== GLITCH TRANSITION BAR ==================== */
.glitch-transition-bar {
    position: fixed;
    left: 0;
    right: 0;
    z-index: 9999;
    pointer-events: none;
    mix-blend-mode: screen;
    animation: glitchBarFlash 0.2s ease-out forwards;
}
@keyframes glitchBarFlash {
    0% {
        opacity: 0;
        transform: scaleX(0.3) translateX(-20%);
    }
    30% {
        opacity: 1;
        transform: scaleX(1.2) translateX(5%);
    }
    60% {
        opacity: 0.6;
        transform: scaleX(0.8) translateX(-3%);
    }
    100% {
        opacity: 0;
        transform: scaleX(0) translateX(0);
    }
}

/* ==================== SCROLL SOUNDWAVE ==================== */
.scroll-soundwave {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30px;
    z-index: 9993;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 2px;
    opacity: 0;
    transition: opacity 0.3s ease;
}

/* ==================== HERO CHARACTER WAVE ==================== */
.hero-char-wave {
    display: inline-block;
    animation: heroCharWaveFloat 3s ease-in-out infinite;
    animation-delay: calc(var(--char-i, 0) * 0.08s);
}
@keyframes heroCharWaveFloat {
    0%, 100% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(-3px);
    }
}

/* ==================== SCROLL DEPTH FOG ==================== */
.scroll-depth-fog {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    transition: opacity 0.6s ease;
}

/* ==================== MOBILE: DISABLE V3/V4 HEAVY EFFECTS ==================== */
@media (max-width: 768px) {
    .idle-particle,
    .doorway-portal-ripple,
    .energy-pulse-dot,
    .konami-flash,
    .konami-firework,
    .holo-rainbow-sweep,
    .breathing-bg-pulse,
    .viewport-light-source,
    .constellation-canvas,
    .glitch-transition-bar,
    .scroll-soundwave,
    .scroll-depth-fog {
        display: none !important;
    }
    .hero-char-wave {
        animation: none !important;
    }
}

/* ==================== REDUCED MOTION: DISABLE V3/V4 ==================== */
@media (prefers-reduced-motion: reduce) {
    .idle-particle,
    .doorway-portal-ripple,
    .energy-pulse-dot,
    .konami-flash,
    .konami-firework,
    .holo-rainbow-sweep,
    .breathing-bg-pulse,
    .viewport-light-source,
    .constellation-canvas,
    .glitch-transition-bar,
    .scroll-soundwave,
    .scroll-depth-fog {
        display: none !important;
    }
    .hero-char-wave {
        animation: none !important;
    }
    .hero-photo.hologram-flicker {
        animation: none !important;
    }
}

/* ============================================================
   FULLSCREEN SECTION SNAP SCROLL — PREMIUM SLIDE-IN CHAMBERS
   Crystal-clear 3D depth animations, NO BLUR
   ============================================================ */

/* Snap scroll container — each section snaps into place */
html {
    scroll-behavior: smooth;
    scroll-snap-type: y mandatory;
    /* Smooth snap without jarring stops */
    scroll-padding-top: 0;
}

/* ==================== SECTION SNAP BEHAVIOR ==================== */
section.chamber {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Hero is the first snap point */
.hero {
    scroll-snap-align: start;
    scroll-snap-stop: always;
}

/* ==================== FULLSCREEN SECTION ENTRANCE ANIMATION ==================== */
/* When a section enters viewport, it slides in with 3D depth */
.chamber {
    transform: perspective(1200px) rotateX(8deg) translateZ(-100px) translateY(60px);
    opacity: 0;
    filter: saturate(0.8);
    transition: all 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.chamber.in-view {
    transform: perspective(1200px) rotateX(0deg) translateZ(0) translateY(0);
    opacity: 1;
    filter: saturate(1);
}

/* Hero section enters from top with scale */
.hero {
    transform: perspective(1200px) rotateX(-6deg) scale(0.95) translateY(-80px);
    opacity: 0;
}

.hero.in-view {
    transform: perspective(1200px) rotateX(0deg) scale(1) translateY(0);
    opacity: 1;
}

/* ==================== 3D ROOM DEPTH PERSPECTIVE ==================== */
/* Each section appears deeper as you scroll */
body {
    perspective: 1000px;
}

.chamber {
    position: relative;
    /* Room parallax depth */
    --depth-z: calc((var(--scroll-position, 0) - var(--section-top, 0)) * 0.1);
}

/* ==================== CRISP EDGE TRANSITIONS (NO BLUR) ==================== */
/* Remove any motion blur effects on sections */
.chamber {
    will-change: transform, opacity;
    backface-visibility: hidden;
    -webkit-font-smoothing: antialiased;
}

/* Gallery effect: sections appear like premium 3D cards */
.chamber::before {
    /* Enhanced room wall glow (CRISP, not blurred) */
    box-shadow:
        inset 0 80px 120px -40px rgba(3,0,20,0.7),
        inset 0 -80px 120px -40px rgba(3,0,20,0.7),
        inset 80px 0 100px -50px rgba(3,0,20,0.4),
        inset -80px 0 100px -50px rgba(3,0,20,0.4),
        /* Crisp edge highlight when entering */
        0 0 40px rgba(129,140,248,0.08);
    transition: all 0.8s var(--ease-bounce), box-shadow 0.8s var(--ease-bounce);
}

.chamber.in-view::before {
    box-shadow:
        inset 0 40px 60px -30px rgba(3,0,20,0.4),
        inset 0 -40px 60px -30px rgba(3,0,20,0.4),
        inset 40px 0 50px -30px rgba(3,0,20,0.2),
        inset -40px 0 50px -30px rgba(3,0,20,0.2),
        /* Crisp glow when section is active */
        0 0 60px rgba(129,140,248,0.15),
        0 0 120px rgba(129,140,248,0.06);
}

/* ==================== CONTENT STAGGER ANIMATION ==================== */
/* Content inside each section fades in staggered after the section slides in */
.chamber .section-header {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s var(--ease-bounce) 0.3s;
}

.chamber.in-view .section-header {
    opacity: 1;
    transform: translateY(0);
}

.chamber .container > * {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s var(--ease-bounce);
}

.chamber.in-view .container > * {
    opacity: 1;
    transform: translateY(0);
}

/* Stagger each child */
.chamber.in-view .about-grid { transition-delay: 0.4s; }
.chamber.in-view .value-cards { transition-delay: 0.3s; }
.chamber.in-view .skills-grid { transition-delay: 0.35s; }
.chamber.in-view .exp-showcase { transition-delay: 0.32s; }
.chamber.in-view .projects-grid { transition-delay: 0.38s; }
.chamber.in-view .ach-grid { transition-delay: 0.36s; }
.chamber.in-view .edu-timeline { transition-delay: 0.34s; }
.chamber.in-view .contact-grid { transition-delay: 0.33s; }

/* ==================== DOORWAY CRISP ENTRANCE EFFECT ==================== */
.doorway {
    opacity: 0;
    transform: scaleY(0.5) translateY(40px);
    transition: all 0.7s var(--ease-bounce);
}

.doorway.in-view {
    opacity: 1;
    transform: scaleY(1) translateY(0);
}

.doorway-arch {
    /* Crisp 3D perspective */
    transform: perspective(800px) rotateX(15deg);
    transition: all 0.6s var(--ease-bounce);
}

.doorway.in-view .doorway-arch {
    transform: perspective(800px) rotateX(0deg);
}

/* Light beam through doorway (crisp gradient, not blurred) */
.doorway-light {
    background: linear-gradient(
        180deg,
        rgba(129,140,248,0.25) 0%,
        rgba(129,140,248,0.08) 50%,
        transparent 100%
    );
    opacity: 0;
    transition: opacity 0.8s var(--ease);
}

.doorway.in-view .doorway-light {
    opacity: 1;
}

/* ==================== SECTION TITLE ENTRANCE WITH CHARACTER WAVE ==================== */
.section-title {
    /* Stagger each character for wave effect */
    display: inline-flex;
    flex-direction: column;
}

.section-title span {
    overflow: hidden;
    display: inline-block;
}

.section-title-char {
    display: inline-block;
    animation: charWaveEnter 0.6s var(--ease-bounce) backwards;
    animation-delay: calc(var(--char-index, 0) * 0.05s);
}

@keyframes charWaveEnter {
    0% {
        opacity: 0;
        transform: translateY(30px) rotateX(-60deg);
    }
    100% {
        opacity: 1;
        transform: translateY(0) rotateX(0deg);
    }
}

/* ==================== PREMIUM 3D CARD TILT ON HOVER ==================== */
.value-card,
.skill-card,
.project-card,
.ach-card,
.cert-card,
.edu-card-apple {
    perspective: 1200px;
    transform: translateZ(0);
    transition: all 0.4s var(--ease);
}

.value-card:hover,
.skill-card:hover,
.project-card:hover,
.ach-card:hover,
.cert-card:hover,
.edu-card-apple:hover {
    /* 3D lift and tilt */
    transform: translateY(-8px) translateZ(20px) rotateX(2deg) rotateY(-1deg);
}

/* ==================== HERO CONTENT STAGGER ==================== */
.hero .hero-text > * {
    opacity: 0;
    transform: translateY(20px);
    animation: heroContentSlideIn 0.8s var(--ease-bounce) forwards;
}

.hero-badge {
    animation-delay: 1s;
}

.hero-title {
    animation-delay: 1.3s;
}

.hero-subtitle {
    animation-delay: 1.5s;
}

.hero-desc {
    animation-delay: 1.7s;
}

.hero-cta {
    animation-delay: 1.9s;
}

.hero-stats {
    animation-delay: 2.1s;
}

@keyframes heroContentSlideIn {
    0% {
        opacity: 0;
        transform: translateY(20px);
        filter: blur(4px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
    }
}

.hero-visual {
    opacity: 0;
    animation: heroPhotoZoomIn 1.2s var(--ease-bounce) 0.8s forwards;
}

@keyframes heroPhotoZoomIn {
    0% {
        opacity: 0;
        transform: scale(0.7) translateY(30px);
        filter: blur(8px);
    }
    100% {
        opacity: 1;
        transform: scale(1) translateY(0);
        filter: blur(0);
    }
}

/* ==================== PHOTO BADGES ENTRANCE ==================== */
.photo-badge {
    opacity: 0;
    animation: badgeFloat 1s var(--ease-bounce) backwards;
}

.photo-badge-1 { animation-delay: 2.2s; }
.photo-badge-2 { animation-delay: 2.4s; }
.photo-badge-3 { animation-delay: 2.6s; }
.photo-badge-4 { animation-delay: 2.8s; }
.photo-badge-5 { animation-delay: 3s; }
.photo-badge-6 { animation-delay: 3.2s; }

@keyframes badgeFloat {
    0% {
        opacity: 0;
        transform: scale(0) translateY(20px);
    }
    100% {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

/* ==================== ABOUT SECTION ENTRANCE ==================== */
.about-left {
    opacity: 0;
    transform: translateX(-50px) rotateY(15deg);
    transition: all 1s var(--ease-bounce) 0.2s;
}

.about-right {
    opacity: 0;
    transform: translateX(50px) rotateY(-15deg);
    transition: all 1s var(--ease-bounce) 0.3s;
}

.chamber.in-view .about-left {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
}

.chamber.in-view .about-right {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
}

/* ==================== SKILL SPHERE ENTRANCE ==================== */
.skill-sphere-canvas {
    opacity: 0;
    transform: scale(0.8) rotateZ(-15deg);
    transition: all 1.2s var(--ease-bounce) 0.2s;
}

.chamber.in-view .skill-sphere-canvas {
    opacity: 1;
    transform: scale(1) rotateZ(0deg);
}

/* ==================== EXPERIENCE CARD STAGGER ==================== */
.exp-card {
    opacity: 0;
    transform: translateX(-60px) rotateY(20deg);
    transition: all 0.9s var(--ease-bounce);
}

.chamber.in-view .exp-card:nth-child(1) {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
    transition-delay: 0.3s;
}

.chamber.in-view .exp-card:nth-child(2) {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
    transition-delay: 0.5s;
}

.chamber.in-view .exp-card:nth-child(3) {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
    transition-delay: 0.7s;
}

/* ==================== PROJECT FEATURED ENTRANCE ==================== */
.project-featured {
    opacity: 0;
    transform: perspective(1200px) rotateX(15deg) translateZ(-80px) scale(0.9);
    transition: all 1.1s var(--ease-bounce) 0.2s;
}

.chamber.in-view .project-featured {
    opacity: 1;
    transform: perspective(1200px) rotateX(0deg) translateZ(0) scale(1);
}

/* Project grid cards */
.project-card {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s var(--ease-bounce);
}

.chamber.in-view .project-card {
    opacity: 1;
    transform: translateY(0);
}

.chamber.in-view .project-card:nth-child(1) { transition-delay: 0.5s; }
.chamber.in-view .project-card:nth-child(2) { transition-delay: 0.65s; }
.chamber.in-view .project-card:nth-child(3) { transition-delay: 0.8s; }
.chamber.in-view .project-card:nth-child(4) { transition-delay: 0.95s; }

/* ==================== ACHIEVEMENT CARDS ENTRANCE WITH PULSE ==================== */
.ach-card {
    opacity: 0;
    transform: scale(0.85) rotateZ(-10deg);
    transition: all 0.9s var(--ease-bounce);
}

.chamber.in-view .ach-card {
    opacity: 1;
    transform: scale(1) rotateZ(0deg);
}

.chamber.in-view .ach-card:nth-child(1) { transition-delay: 0.3s; }
.chamber.in-view .ach-card:nth-child(2) { transition-delay: 0.45s; }
.chamber.in-view .ach-card:nth-child(3) { transition-delay: 0.6s; }
.chamber.in-view .ach-card:nth-child(4) { transition-delay: 0.75s; }

/* Achievement icon pulse on enter */
.ach-icon {
    animation: iconPulseEnter 0.8s var(--ease-bounce) forwards;
}

.chamber.in-view .ach-icon {
    animation: iconPulseEnter 0.6s var(--ease-bounce) forwards;
}

@keyframes iconPulseEnter {
    0% {
        transform: scale(0) rotate(-180deg);
        opacity: 0;
    }
    70% {
        transform: scale(1.2) rotate(10deg);
        opacity: 1;
    }
    100% {
        transform: scale(1) rotate(0deg);
        opacity: 1;
    }
}

/* ==================== EDUCATION TIMELINE ENTRANCE ==================== */
.edu-item {
    opacity: 0;
    transform: translateX(-80px) rotateY(20deg);
    transition: all 0.9s var(--ease-bounce);
}

.chamber.in-view .edu-item {
    opacity: 1;
    transform: translateX(0) rotateY(0deg);
}

.chamber.in-view .edu-item:nth-child(1) { transition-delay: 0.2s; }
.chamber.in-view .edu-item:nth-child(2) { transition-delay: 0.4s; }
.chamber.in-view .edu-item:nth-child(3) { transition-delay: 0.6s; }

/* ==================== CONTACT SECTION ENTRANCE ==================== */
.contact-links {
    opacity: 0;
    transform: translateX(-60px);
    transition: all 1s var (--ease-bounce) 0.2s;
}

.contact-form {
    opacity: 0;
    transform: translateX(60px);
    transition: all 1s var (--ease-bounce) 0.3s;
}

.chamber.in-view .contact-links {
    opacity: 1;
    transform: translateX(0);
}

.chamber.in-view .contact-form {
    opacity: 1;
    transform: translateX(0);
}

.contact-row {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.7s var(--ease-bounce);
}

.chamber.in-view .contact-row {
    opacity: 1;
    transform: translateY(0);
}

.chamber.in-view .contact-row:nth-child(1) { transition-delay: 0.4s; }
.chamber.in-view .contact-row:nth-child(2) { transition-delay: 0.55s; }
.chamber.in-view .contact-row:nth-child(3) { transition-delay: 0.7s; }
.chamber.in-view .contact-row:nth-child(4) { transition-delay: 0.85s; }

/* ==================== MOBILE RESPONSIVE SNAP SCROLL ==================== */
@media (max-width: 768px) {
    html {
        scroll-snap-type: y proximity;
        /* Less aggressive snapping on mobile */
    }

    section.chamber {
        scroll-snap-align: center;
        min-height: auto;
        padding: 40px 0;
    }

    .chamber {
        transform: translateY(40px);
        opacity: 0;
    }

    .chamber.in-view {
        transform: translateY(0);
        opacity: 1;
    }

    /* Simpler entrance on mobile */
    .about-left,
    .about-right,
    .contact-links,
    .contact-form {
        transform: translateY(20px);
    }

    .chamber.in-view .about-left,
    .chamber.in-view .about-right,
    .chamber.in-view .contact-links,
    .chamber.in-view .contact-form {
        transform: translateY(0);
    }
}

/* ==================== REDUCED MOTION: RESPECT PREFERENCES ==================== */
@media (prefers-reduced-motion: reduce) {
    html {
        scroll-snap-type: none;
    }

    .chamber,
    .chamber.in-view,
    .chamber .section-header,
    .chamber.in-view .section-header,
    .hero,
    .hero.in-view,
    .hero .hero-text > *,
    .hero-visual,
    .photo-badge,
    .about-left,
    .about-right,
    .skill-sphere-canvas,
    .exp-card,
    .project-featured,
    .project-card,
    .ach-card,
    .edu-item,
    .contact-links,
    .contact-form,
    .contact-row {
        animation: none !important;
        transition: none !important;
        opacity: 1 !important;
        transform: none !important;
        filter: none !important;
    }
}

/* ============================================================
   DEPTH INDICATOR — ELEVATOR SHAFT ON RIGHT SIDE
   Shows current chamber floor as you descend
   ============================================================ */

.depth-indicator {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s var(--ease);
}

.depth-indicator.visible {
    opacity: 1;
    pointer-events: auto;
}

.depth-labels {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 16px;
}

.depth-label {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(30, 27, 75, 0.6);
    border: 1.5px solid rgba(129, 140, 248, 0.3);
    font-size: 11px;
    font-weight: 700;
    color: rgba(129, 140, 248, 0.6);
    cursor: pointer;
    transition: all 0.3s var(--ease);
    backdrop-filter: blur(8px);
}

.depth-label:hover {
    background: rgba(30, 27, 75, 0.9);
    border-color: rgba(129, 140, 248, 0.8);
    color: rgba(129, 140, 248, 1);
    transform: scale(1.15);
}

.depth-label.active {
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.8), rgba(192, 132, 252, 0.8));
    border-color: rgba(129, 140, 248, 1);
    color: #fff;
    box-shadow: 0 0 20px rgba(129, 140, 248, 0.6);
    transform: scale(1.25);
}

.depth-shaft {
    position: relative;
    width: 3px;
    height: 200px;
    background: linear-gradient(180deg, rgba(129, 140, 248, 0.1), rgba(129, 140, 248, 0.3), rgba(129, 140, 248, 0.1));
    border-radius: 2px;
    margin: 0 auto;
}

.depth-elevator {
    position: absolute;
    width: 3px;
    height: 22px;
    background: linear-gradient(90deg, rgba(129, 140, 248, 0.8), rgba(192, 132, 252, 0.8));
    border-radius: 2px;
    left: 0;
    top: 0;
    box-shadow: 0 0 15px rgba(129, 140, 248, 0.6);
    transition: top 0.6s var(--ease-cubic);
}

@media (max-width: 768px) {
    .depth-indicator {
        display: none;
    }
}

/* ============================================================
   ROOM AMBIENCE PARTICLES
   Floating symbols specific to each chamber
   ============================================================ */

.room-ambient {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
}

.room-particle {
    position: absolute;
    font-size: 32px;
    opacity: 0;
    animation: particleFloat 8s infinite ease-in-out;
    filter: drop-shadow(0 0 10px rgba(129, 140, 248, 0.3));
}

.room-particle:nth-child(1) {
    left: 10%;
    top: 15%;
    animation-delay: 0s;
}

.room-particle:nth-child(2) {
    left: 20%;
    top: 70%;
    animation-delay: 1.2s;
}

.room-particle:nth-child(3) {
    right: 15%;
    top: 25%;
    animation-delay: 2.4s;
}

.room-particle:nth-child(4) {
    right: 25%;
    top: 75%;
    animation-delay: 3.6s;
}

.room-particle:nth-child(5) {
    left: 50%;
    top: 50%;
    animation-delay: 4.8s;
}

@keyframes particleFloat {
    0%, 100% {
        opacity: 0;
        transform: translateY(40px) scale(0.8);
    }
    25% {
        opacity: 0.6;
        transform: translateY(-20px) scale(1);
    }
    50% {
        opacity: 0.8;
        transform: translateY(-80px) scale(1.1);
    }
    75% {
        opacity: 0.4;
        transform: translateY(-40px) scale(0.9);
    }
}

/* Room-specific particle effects */
.room-ambient-story .room-particle {
    filter: drop-shadow(0 0 10px rgba(147, 112, 219, 0.4));
}

.room-ambient-power .room-particle {
    filter: drop-shadow(0 0 10px rgba(255, 107, 107, 0.4));
    animation-duration: 6s;
}

.room-ambient-arsenal .room-particle {
    filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.4));
    animation-duration: 7s;
}

.room-ambient-lab .room-particle {
    filter: drop-shadow(0 0 10px rgba(52, 211, 153, 0.4));
    animation-duration: 9s;
}

.room-ambient-trophy .room-particle {
    filter: drop-shadow(0 0 10px rgba(251, 191, 36, 0.4));
    animation-duration: 5s;
}

.room-ambient-archive .room-particle {
    filter: drop-shadow(0 0 10px rgba(129, 140, 248, 0.4));
    animation-duration: 8s;
}

.room-ambient-comms .room-particle {
    filter: drop-shadow(0 0 10px rgba(192, 132, 252, 0.4));
    animation-duration: 6.5s;
}

/* ============================================================
   MINI-NIKHIL IN-ROOM SCENES
   Contextual avatar with room-specific actions
   ============================================================ */

.room-mini-nikhil {
    position: absolute;
    bottom: 40px;
    left: 40px;
    width: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    z-index: 50;
    opacity: 0;
    animation: miniNikhilAppear 1s var(--ease-bounce) forwards;
    animation-delay: 0.8s;
}

@keyframes miniNikhilAppear {
    0% {
        opacity: 0;
        transform: scale(0) translateY(40px);
    }
    100% {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.rmn-face {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(129, 140, 248, 0.5);
    box-shadow: 0 0 25px rgba(129, 140, 248, 0.3);
    animation: faceHover 3s ease-in-out infinite;
}

@keyframes faceHover {
    0%, 100% {
        transform: translateY(0) scale(1);
    }
    50% {
        transform: translateY(-8px) scale(1.05);
    }
}

.rmn-action {
    position: absolute;
    font-size: 32px;
    animation: actionFloat 2s ease-in-out infinite;
}

.rmn-book { animation-delay: 0s; left: -20px; top: 20px; }
.rmn-thought { animation-delay: 0.2s; right: 10px; top: 10px; animation-name: thoughtBubble; }
.rmn-flex { animation-delay: 0s; right: -15px; top: 30px; animation-name: flexPulse; }
.rmn-aura { animation-delay: 0.3s; }
.rmn-laptop { animation-delay: 0s; right: -20px; bottom: 20px; animation-name: laptopGlow; }
.rmn-wrench { animation-delay: 0s; left: -25px; bottom: 15px; }
.rmn-trophy-hold { animation-delay: 0s; right: -15px; top: 10px; animation-name: trophyHold; }
.rmn-desk-lamp { animation-delay: 0s; left: -20px; top: 20px; animation-name: lampFlicker; }
.rmn-books-stack { font-size: 24px; position: absolute; right: -10px; bottom: 15px; animation: booksStack 2.5s ease-in-out infinite; }
.rmn-wave-hand { animation-delay: 0s; right: -20px; top: 15px; animation-name: waveHand; }

@keyframes actionFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(5deg); }
}

@keyframes thoughtBubble {
    0%, 100% { opacity: 0.6; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.1); }
}

@keyframes flexPulse {
    0%, 100% { transform: scale(1) rotate(-10deg); }
    50% { transform: scale(1.3) rotate(10deg); }
}

@keyframes laptopGlow {
    0%, 100% { transform: rotate(-15deg); filter: drop-shadow(0 0 5px rgba(34, 211, 238, 0.5)); }
    50% { transform: rotate(5deg); filter: drop-shadow(0 0 15px rgba(34, 211, 238, 0.8)); }
}

@keyframes trophyHold {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.15); }
}

@keyframes lampFlicker {
    0%, 100% { opacity: 0.8; }
    10%, 15% { opacity: 0.3; }
    20%, 100% { opacity: 0.8; }
}

@keyframes booksStack {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px) rotate(2deg); }
}

@keyframes waveHand {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(20deg); }
    50% { transform: rotate(0deg); }
    75% { transform: rotate(-20deg); }
}

/* Aura effect for power section */
.rmn-aura {
    position: absolute;
    width: 100px;
    height: 100px;
    border: 2px solid rgba(255, 107, 107, 0.4);
    border-radius: 50%;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    animation: auraExpand 2s ease-out infinite;
}

@keyframes auraExpand {
    0% {
        width: 100px;
        height: 100px;
        opacity: 1;
    }
    100% {
        width: 160px;
        height: 160px;
        opacity: 0;
    }
}

/* Typing dots for arsenal section */
.rmn-typing-dots {
    display: flex;
    gap: 4px;
    position: absolute;
    right: -30px;
    bottom: 20px;
}

.rmn-typing-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(34, 211, 238, 0.7);
    animation: typingDot 1.4s infinite;
}

.rmn-typing-dots span:nth-child(2) { animation-delay: 0.2s; }
.rmn-typing-dots span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingDot {
    0%, 60%, 100% {
        opacity: 0.3;
        transform: translateY(0);
    }
    30% {
        opacity: 1;
        transform: translateY(-6px);
    }
}

/* Sparks for lab section */
.rmn-sparks {
    position: absolute;
    right: -30px;
    top: 30px;
    font-size: 20px;
}

.rmn-sparks span {
    position: absolute;
    animation: sparkShoot 1s ease-out infinite;
}

.rmn-sparks span:nth-child(1) { animation-delay: 0s; }
.rmn-sparks span:nth-child(2) { animation-delay: 0.3s; }
.rmn-sparks span:nth-child(3) { animation-delay: 0.6s; }

@keyframes sparkShoot {
    0% {
        opacity: 1;
        transform: translate(0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(30px, -30px) scale(0);
    }
}

/* Confetti for trophy section */
.rmn-confetti-burst {
    position: absolute;
    right: -25px;
    top: 15px;
    font-size: 24px;
}

.rmn-confetti-burst span {
    position: absolute;
    animation: confettiFall 1.8s ease-out infinite;
}

.rmn-confetti-burst span:nth-child(1) { animation-delay: 0s; left: 0; }
.rmn-confetti-burst span:nth-child(2) { animation-delay: 0.2s; left: 15px; }
.rmn-confetti-burst span:nth-child(3) { animation-delay: 0.4s; left: -15px; }

@keyframes confettiFall {
    0% {
        opacity: 1;
        transform: translateY(-20px) rotate(0deg);
    }
    100% {
        opacity: 0;
        transform: translateY(60px) rotate(360deg);
    }
}

/* Zzz for education section */
.rmn-zzz {
    position: absolute;
    right: -20px;
    top: 20px;
    font-size: 16px;
    color: rgba(129, 140, 248, 0.7);
}

.rmn-zzz span {
    display: inline-block;
    animation: zzzFloat 2s ease-in-out infinite;
}

.rmn-zzz span:nth-child(1) { animation-delay: 0s; }
.rmn-zzz span:nth-child(2) { animation-delay: 0.3s; }
.rmn-zzz span:nth-child(3) { animation-delay: 0.6s; }

@keyframes zzzFloat {
    0%, 100% {
        opacity: 0.3;
        transform: translateY(0);
    }
    50% {
        opacity: 1;
        transform: translateY(-15px);
    }
}

/* Hearts for contact section */
.rmn-heart-burst {
    position: absolute;
    right: -30px;
    bottom: 25px;
    font-size: 20px;
}

.rmn-heart-burst span {
    position: absolute;
    animation: heartFloat 2s ease-out infinite;
}

.rmn-heart-burst span:nth-child(1) { animation-delay: 0s; }
.rmn-heart-burst span:nth-child(2) { animation-delay: 0.3s; }
.rmn-heart-burst span:nth-child(3) { animation-delay: 0.6s; }

@keyframes heartFloat {
    0% {
        opacity: 1;
        transform: translate(0) scale(1) rotate(0deg);
    }
    100% {
        opacity: 0;
        transform: translate(40px, -80px) scale(0) rotate(360deg);
    }
}

/* Speech bubble */
.rmn-speech-bubble {
    background: rgba(30, 27, 75, 0.8);
    border: 1.5px solid rgba(129, 140, 248, 0.5);
    border-radius: 12px;
    padding: 8px 12px;
    font-size: 12px;
    color: rgba(129, 140, 248, 0.9);
    white-space: nowrap;
    backdrop-filter: blur(8px);
    position: relative;
    animation: speechBubbleFloat 0.6s var(--ease-bounce);
}

.rmn-speech-bubble::before {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background: rgba(30, 27, 75, 0.8);
    border: 1.5px solid rgba(129, 140, 248, 0.5);
    border-radius: 50%;
    bottom: -10px;
    left: 12px;
}

@keyframes speechBubbleFloat {
    0% {
        opacity: 0;
        transform: translateY(-10px) scale(0.8);
    }
    100% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@media (max-width: 768px) {
    .room-mini-nikhil {
        width: 80px;
        bottom: 20px;
        left: 20px;
    }

    .rmn-face {
        width: 60px;
        height: 60px;
    }

    .rmn-action {
        font-size: 24px;
    }

    .rmn-speech-bubble {
        font-size: 10px;
        padding: 6px 10px;
    }
}

/* ============================================================
   DOORWAY TRANSITIONS
   Portal effects when entering new chambers
   ============================================================ */

.doorway {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at center, rgba(30, 27, 75, 0.4), rgba(10, 3, 50, 0.9));
    z-index: 100;
    overflow: hidden;
}

.doorway::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, transparent 30%, rgba(129, 140, 248, 0.1) 50%, transparent 70%);
    animation: doorwaySweep 1.5s ease-in-out;
}

@keyframes doorwaySweep {
    0% {
        transform: translateX(-100%);
    }
    100% {
        transform: translateX(100%);
    }
}

.doorway-frame {
    position: relative;
    width: 300px;
    height: 450px;
    perspective: 1200px;
}

.doorway-arch {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 3px solid rgba(129, 140, 248, 0.6);
    border-radius: 50% 50% 0 0;
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.1), rgba(192, 132, 252, 0.1));
    box-shadow:
        inset 0 0 40px rgba(129, 140, 248, 0.3),
        0 0 60px rgba(129, 140, 248, 0.2);
}

.doorway-light {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background: linear-gradient(
        180deg,
        rgba(129, 140, 248, 0.3) 0%,
        rgba(192, 132, 252, 0.2) 50%,
        transparent 100%
    );
    border-radius: 50% 50% 0 0;
    animation: doorwayLightPulse 1.2s ease-out;
}

@keyframes doorwayLightPulse {
    0% {
        opacity: 0;
        filter: blur(20px);
    }
    50% {
        opacity: 1;
        filter: blur(10px);
    }
    100% {
        opacity: 0.6;
        filter: blur(0px);
    }
}

.doorway-walker {
    position: absolute;
    width: 60px;
    height: 100px;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: doorwayWalk 1.8s ease-in-out forwards;
    opacity: 0;
}

@keyframes doorwayWalk {
    0% {
        opacity: 1;
        transform: translate(-50%, 100%) scale(0.5);
        filter: blur(5px);
    }
    50% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
    }
    100% {
        opacity: 0;
        transform: translate(-50%, -200%) scale(0.5);
        filter: blur(5px);
    }
}

.dw-face {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(129, 140, 248, 0.7);
}

.dw-legs {
    position: relative;
    width: 20px;
    height: 45px;
    margin-top: 8px;
}

.dw-leg {
    position: absolute;
    width: 6px;
    height: 35px;
    background: rgba(129, 140, 248, 0.7);
    border-radius: 3px;
    bottom: 0;
    animation: walkingLeg 0.8s ease-in-out infinite;
}

.dw-leg-l {
    left: 0;
    animation-delay: 0s;
}

.dw-leg-r {
    right: 0;
    animation-delay: 0.4s;
}

@keyframes walkingLeg {
    0%, 100% {
        transform: rotateZ(-25deg);
    }
    50% {
        transform: rotateZ(25deg);
    }
}

.doorway-label {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: rgba(129, 140, 248, 0.8);
    text-align: center;
    animation: doorwayLabelFade 1.8s ease-out;
}

.doorway-label strong {
    color: rgba(192, 132, 252, 1);
    font-weight: 700;
}

@keyframes doorwayLabelFade {
    0% {
        opacity: 0;
        transform: translateX(-50%) translateY(20px);
    }
    40% {
        opacity: 1;
    }
    100% {
        opacity: 0;
        transform: translateX(-50%) translateY(-20px);
    }
}

.doorway-depth-line {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 80px;
    background: linear-gradient(180deg, rgba(129, 140, 248, 0.6), transparent);
    animation: depthLineExtend 1.8s ease-out;
}

@keyframes depthLineExtend {
    0% {
        height: 20px;
        opacity: 0;
    }
    50% {
        opacity: 1;
    }
    100% {
        height: 80px;
        opacity: 0;
    }
}

/* Doorway entrance animation class */
.doorway.in-view {
    animation: doorwayEnter 0.8s var(--ease-bounce) forwards;
}

@keyframes doorwayEnter {
    0% {
        opacity: 0;
        transform: scaleY(0.3) translateY(40px);
    }
    100% {
        opacity: 1;
        transform: scaleY(1) translateY(0);
    }
}

@media (max-width: 768px) {
    .doorway-frame {
        width: 250px;
        height: 350px;
    }

    .dw-face {
        width: 30px;
        height: 30px;
    }

    .doorway-label {
        font-size: 12px;
    }
}

/* ============================================================
   BOT TRAIL PARTICLE EFFECT
   Mini particle trail following Nikhil bot
   ============================================================ */

.bot-trail {
    position: fixed;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(129, 140, 248, 0.8), rgba(129, 140, 248, 0));
    pointer-events: none;
    animation: trailFade 0.6s ease-out forwards;
    z-index: 999;
}

@keyframes trailFade {
    0% {
        opacity: 1;
        transform: scale(1);
    }
    100% {
        opacity: 0;
        transform: scale(0);
    }
}